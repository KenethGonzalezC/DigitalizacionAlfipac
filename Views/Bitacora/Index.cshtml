@model List<BitacoraAlfipac.Models.ViewModels.BitacoraDiaVM>

@{
    var fecha = ViewBag.FechaSeleccionada as DateTime? ?? DateTime.Today;
    ViewData["Title"] = $"Bitácora del día - {fecha:dd/MM/yyyy}";
}

<div class="container mt-4">

    <!-- ENCABEZADO + BUSCADOR -->
    <form method="get" class="d-flex align-items-center gap-3 mb-4">
        <h2 class="fw-semibold mb-0">
            Bitácora del dia – @fecha.ToString("dd/MM/yyyy")
        </h2>

        <input type="date"
               name="fecha"
               class="form-control w-auto"
               value="@fecha.ToString("yyyy-MM-dd")" />

        <button type="submit" class="btn btn-outline-primary">
            Confirmar
        </button>

        <div>
            <button type="button"
                    class="btn btn-danger"
                    data-bs-toggle="modal"
                    data-bs-target="#modalExportarPdf">
                Exportar PDF
            </button>
        </div>

        <div>
        <a asp-action="ExportarExcel"
           asp-route-fecha="@fecha.ToString("yyyy-MM-dd")"
           class="btn btn-success">
            Exportar Excel
        </a>
        </div>

    </form>


    <!-- TABLA -->
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0 text-center">
                <thead class="table-light">
                    <tr>
                        <th>Contenedor</th>
                        <th>Marchamos</th>
                        <th>Hora Entrada</th>
                        <th>Hora Salida</th>
                        <th>Transportista</th>
                        <th>Información</th>
                        <th>Chofer</th>
                        <th>Placa</th>
                        <th>Chasis</th>
                        <th>Viaje / DUA</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-4">
                                No existen movimientos para esta fecha
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.Contenedor</td>
                                <td>@item.Marchamos</td>

                                <td class="fw-bold">
                                    @(item.HoraEntrada?.ToString("HH:mm") ?? "")
                                </td>

                                <td class="fw-bold">
                                    @(item.HoraSalida?.ToString("HH:mm") ?? "")
                                </td>

                                <td>@item.Transportista</td>
                                <td>@item.Informacion</td>
                                <td>@item.Chofer</td>
                                <td>@item.Placa</td>
                                <td>@item.Chasis</td>
                                <td>@item.ViajeODua</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

<div class="modal fade" id="modalExportarPdf" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <form asp-action="ExportarPdf" method="get">

                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Exportar Bitácora</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input type="hidden" name="fecha" value="@fecha.ToString("yyyy-MM-dd")" />

                    <div class="form-check mb-3">
                        <input type="checkbox" id="todoDia" class="form-check-input" />
                        <label class="form-check-label">Todo el día</label>
                    </div>

                    <div id="rangoHoras" class="row g-2" style="display:none;">
                        <div class="col">
                            <label>Hora inicio</label>
                            <input type="time" name="horaInicio" class="form-control" />
                        </div>
                        <div class="col">
                            <label>Hora fin</label>
                            <input type="time" name="horaFin" class="form-control" />
                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-danger">Exportar</button>
                </div>

            </form>

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const chk = document.getElementById("todoDia");
        const rango = document.getElementById("rangoHoras");
        const horaInicio = document.querySelector("input[name='horaInicio']");
        const horaFin = document.querySelector("input[name='horaFin']");

        function toggleRango() {
            if (chk.checked) {
                rango.style.display = "none";

                // 🔴 CLAVE: desactivar inputs
                horaInicio.disabled = true;
                horaFin.disabled = true;

            } else {
                rango.style.display = "flex";

                horaInicio.disabled = false;
                horaFin.disabled = false;
            }
        }

        chk.addEventListener("change", toggleRango);

        // Estado inicial
        toggleRango();
    });
</script>