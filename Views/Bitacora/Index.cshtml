@model List<BitacoraAlfipac.Models.ViewModels.BitacoraDiaVM>

@{
    var fecha = ViewBag.FechaSeleccionada as DateTime? ?? DateTime.Today;
    ViewData["Title"] = $"Bitácora del día - {fecha:dd/MM/yyyy}";
}

<div class="container mt-4">

    <!-- ENCABEZADO + BUSCADOR -->
    <form method="get" class="d-flex align-items-center gap-3 mb-4">
        <h2 class="fw-semibold mb-0">
            Bitácora del dia – @fecha.ToString("dd/MM/yyyy")
        </h2>

        <input type="date"
               name="fecha"
               class="form-control w-auto"
               value="@fecha.ToString("yyyy-MM-dd")" />

        <button type="submit" class="btn btn-outline-primary">
            Confirmar
        </button>

        <div>
        <a asp-action="ExportarPdf"
           asp-route-fecha="@fecha.ToString("yyyy-MM-dd")"
           class="btn btn-danger">
            Exportar PDF
        </a>
        </div>

        <div>
        <a asp-action="ExportarExcel"
           asp-route-fecha="@fecha.ToString("yyyy-MM-dd")"
           class="btn btn-success">
            Exportar Excel
        </a>
        </div>

    </form>


    <!-- TABLA -->
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0 text-center">
                <thead class="table-light">
                    <tr>
                        <th>Contenedor</th>
                        <th>Marchamos</th>
                        <th>Hora Entrada</th>
                        <th>Hora Salida</th>
                        <th>Transportista</th>
                        <th>Información</th>
                        <th>Chofer</th>
                        <th>Placa</th>
                        <th>Chasis</th>
                        <th>Viaje / DUA</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-4">
                                No existen movimientos para esta fecha
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.Contenedor</td>
                                <td>@item.Marchamos</td>

                                <td class="fw-bold">
                                    @(item.HoraEntrada?.ToString("HH:mm") ?? "")
                                </td>

                                <td class="fw-bold">
                                    @(item.HoraSalida?.ToString("HH:mm") ?? "")
                                </td>

                                <td>@item.Transportista</td>
                                <td>@item.Informacion</td>
                                <td>@item.Chofer</td>
                                <td>@item.Placa</td>
                                <td>@item.Chasis</td>
                                <td>@item.ViajeODua</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>
