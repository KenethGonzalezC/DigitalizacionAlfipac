@{
    ViewData["Title"] = "Módulo Datos";
}

<div class="container mt-4">

    <h2 class="mb-4">Módulo de Datos</h2>

    <div class="row g-4">

        <div class="col-md-6">
            <a asp-controller="Datos" asp-action="Ingresos" class="text-decoration-none">
                <div class="card shadow-sm h-100 border-primary">
                    <div class="card-body text-center">
                        <h4 class="text-primary">Ingresos por Viaje</h4>
                        <p class="text-muted">Registro anticipado de información de viajes de ingreso</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6">
            <a asp-controller="Datos" asp-action="Despachos" class="text-decoration-none">
                <div class="card shadow-sm h-100 border-primary">
                    <div class="card-body text-center">
                        <h4 class="text-primary">Despachos</h4>
                        <p class="text-muted">Registro anticipado de información de viajes de despacho</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6">
            <a asp-controller="Transportistas" asp-action="Index" class="text-decoration-none">
                <div class="card shadow-sm h-100 border-success">
                    <div class="card-body text-center">
                        <h4 class="text-success">Transportistas Autorizados</h4>
                        <p class="text-muted">Administración de transportistas habilitados</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6">
            <a asp-controller="Vacios" asp-action="Index" class="text-decoration-none">
                <div class="card shadow-sm h-100 border-success">
                    <div class="card-body text-center">
                        <h4 class="text-success">Vacíos</h4>
                        <p class="text-muted">Reporte de contenedores vacíos en el almacén</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>
