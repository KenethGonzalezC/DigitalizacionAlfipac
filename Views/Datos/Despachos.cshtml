@model List<BitacoraAlfipac.Models.Entidades.DatosDespachoViaje>

@{
    ViewData["Title"] = "Datos de Despachos";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h3 class="mb-0">📦 Datos Anticipados de Despachos</h3>
            <small class="text-muted">Gestión de información previa a salida de contenedores</small>
        </div>

        <a asp-action="Index" class="btn btn-outline-dark">
            ← Volver
        </a>
    </div>

    <div class="mb-3">
        <span class="badge bg-primary fs-6 px-3 py-2">
            📦 Despachos pendientes: @ViewBag.TotalContenedores
        </span>
    </div>

    <!-- ================= FORMULARIO ================= -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
            Registrar despacho anticipado
        </div>

        <div class="card-body">

            <form asp-action="CrearDespacho" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-3">

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Contenedor</label>
                        <div class="input-group">
                            <input name="Contenedor"
                                   id="contenedorInput"
                                   class="form-control"
                                   required />

                            <button type="button"
                                    id="btnBuscarContenedor"
                                    class="btn btn-outline-primary">
                                🔍
                            </button>
                        </div>
                        <small id="infoPatio" class="text-muted fw-bold d-block mt-1"></small>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Marchamos</label>
                        <input name="Marchamos" id="marchamosInput" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Transportista</label>
                        <input name="Transportista" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Cliente</label>
                        <input name="Cliente" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Chasis</label>
                        <input name="Chasis" id="chasisInput" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Chofer</label>
                        <input name="Chofer" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Placa Cabezal</label>
                        <input name="PlacaCabezal" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Viaje / DUA</label>
                        <input name="ViajeDua" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Boleta</label>
                        <input name="Boleta" class="form-control" />
                    </div>

                </div>

                <div class="mt-3 text-end">
                    <button class="btn btn-primary">
                        💾 Guardar
                    </button>
                </div>

            </form>

        </div>
    </div>

    <!-- ================= FILTROS ================= -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <form method="get">
                <div class="row g-2">

                    <div class="col-md">
                        <input name="contenedor" value="@ViewBag.Contenedor" class="form-control" placeholder="Contenedor" />
                    </div>

                    <div class="col-md">
                        <input name="transportista" value="@ViewBag.Transportista" class="form-control" placeholder="Transportista" />
                    </div>

                    <div class="col-md">
                        <input name="cliente" value="@ViewBag.Cliente" class="form-control" placeholder="Cliente" />
                    </div>

                    <div class="col-md">
                        <input name="viajeDua" value="@ViewBag.ViajeDua" class="form-control" placeholder="Viaje / DUA" />
                    </div>

                    <div class="col-md">
                        <input name="Boleta" value="@ViewBag.Boleta" class="form-control" placeholder="Boleta" />
                    </div>

                    <div class="col-md">
                        <input type="date" name="fechaRegistro" value="@ViewBag.FechaRegistro" class="form-control" />
                    </div>

                    <div class="col-md-3 d-flex gap-2">
                        <button class="btn btn-outline-primary w-100">Filtrar</button>
                        <button type="button" onclick="limpiarFiltros()" class="btn btn-outline-secondary w-100">Limpiar</button>
                    </div>

                </div>
            </form>

        </div>
    </div>

    <!-- ================= TABLA ================= -->
    <div class="card shadow-sm">

        <div class="card-header bg-light">
            <strong>Listado de despachos</strong>
        </div>

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-dark text-center">
                    <tr>
                        <th>Contenedor</th>
                        <th>Marchamos</th>
                        <th>Transportista</th>
                        <th>Cliente</th>
                        <th>Chasis</th>
                        <th>Chofer</th>
                        <th>Placa</th>
                        <th>Viaje/DUA</th>
                        <th>Boleta</th>
                        <th>Acciones</th>
                    </tr>
                </thead>

                <tbody>

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-4">
                                Sin registros
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Contenedor</td>
                                <td>@item.Marchamos</td>
                                <td>@item.Transportista</td>
                                <td>@item.Cliente</td>
                                <td>@item.Chasis</td>
                                <td>@item.Chofer</td>
                                <td>@item.PlacaCabezal</td>
                                <td>@item.ViajeDua</td>
                                <td>@item.Boleta</td>

                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">

                                        <button class="btn btn-sm btn-outline-primary"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editarModal"
                                                onclick="cargarEditar(@item.Id)">
                                            ✏️
                                        </button>

                                        <button class="btn btn-sm btn-outline-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal"
                                                data-id="@item.Id"
                                                data-contenedor="@item.Contenedor">
                                            🗑
                                        </button>

                                    </div>
                                </td>

                            </tr>
                        }
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>


<!-- ================= MODAL EDITAR ================= -->
<div class="modal fade" id="editarModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content shadow">

            <form method="post" asp-action="EditarDespacho">
                @Html.AntiForgeryToken()

                <!-- HEADER -->
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">✏️ Editar despacho</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <!-- BODY -->
                <div class="modal-body">

                    <input type="hidden" name="Id" id="editId" />

                    <div class="row g-3">

                        <div class="col-md-4">
                            <label class="form-label">Contenedor</label>
                            <input name="Contenedor" id="editContenedor" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Marchamos</label>
                            <input name="Marchamos" id="editMarchamos" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Transportista</label>
                            <input name="Transportista" id="editTransportista" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Cliente</label>
                            <input name="Cliente" id="editCliente" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Chofer</label>
                            <input name="Chofer" id="editChofer" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Placa Cabezal</label>
                            <input name="PlacaCabezal" id="editPlaca" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Chasis</label>
                            <input name="Chasis" id="editChasis" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Viaje / DUA</label>
                            <input name="ViajeDua" id="editViajeDua" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Boleta</label>
                            <input name="Boleta" id="editBoleta" class="form-control" />
                        </div>

                    </div>

                </div>

                <!-- FOOTER -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button class="btn btn-primary">
                        💾 Guardar cambios
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- ================= MODAL ELIMINAR ================= -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">

            <form method="post" asp-action="EliminarDespacho">
                @Html.AntiForgeryToken()

                <!-- HEADER -->
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">🗑 Eliminar despacho</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <!-- BODY -->
                <div class="modal-body text-center">

                    <input type="hidden" name="id" id="deleteId" />

                    <div class="mb-2">
                        <span class="badge bg-secondary">Contenedor</span>
                    </div>

                    <h5 class="fw-bold text-danger">
                        <span id="deleteContenedor"></span>
                    </h5>

                    <p class="text-muted mt-3">
                        Esta acción no se puede deshacer.
                    </p>

                </div>

                <!-- FOOTER -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button class="btn btn-danger">
                        Sí, eliminar
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- ================= SCRIPTS ================= -->

<script>

    const datos = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

    function cargarEditar(id) {

        const item = datos.find(x => x.Id === id);
        if (!item) return;

        document.getElementById("editId").value = item.Id;
        document.getElementById("editContenedor").value = item.Contenedor;
        document.getElementById("editMarchamos").value = item.Marchamos;
        document.getElementById("editTransportista").value = item.Transportista;
        document.getElementById("editCliente").value = item.Cliente;
        document.getElementById("editChofer").value = item.Chofer;
        document.getElementById("editPlaca").value = item.PlacaCabezal;
        document.getElementById("editChasis").value = item.Chasis;
        document.getElementById("editViajeDua").value = item.ViajeDua;
        document.getElementById("editBoleta").value = item.Boleta;

        document.getElementById("tituloContenedor").textContent = item.Contenedor;
    }

</script>

<script>
    const deleteModal = document.getElementById('deleteModal');

    deleteModal.addEventListener('show.bs.modal', event => {

        const button = event.relatedTarget;

        document.getElementById('deleteId').value = button.dataset.id;
        document.getElementById('deleteContenedor').textContent =
            button.dataset.contenedor;

    });
</script>

<script>
    function limpiarFiltros() {
        const url = new URL(window.location);
        url.search = '';
        window.location.href = url.toString();
    }
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        function buscarContenedor() {

            const contenedor = document.getElementById("contenedorInput").value.trim();
            if (!contenedor) return;

            fetch(`/BitacoraDespachos/BuscarParaDespacho?contenedor=${contenedor}`)
                .then(r => r.json())
                .then(data => {

                    const infoPatio = document.getElementById("infoPatio");

                    if (!data.encontrado) {
                        infoPatio.innerText =
                            data.mensaje ?? "⚠ Contenedor no está en inventario";
                        return;
                    }

                    infoPatio.innerText =
                        `Ubicación actual: ${data.patio} | Estado: ${data.estado}`;

                    document.getElementById("marchamosInput").value =
                        data.marchamos || "";

                    document.querySelector("[name='Transportista']").value =
                        data.transportista || "";

                    document.getElementById("chasisInput").value =
                        data.chasis || "";

                    const clienteInput =
                        document.querySelector("[name='Cliente']");

                    if (clienteInput && !clienteInput.value)
                        clienteInput.value = data.cliente || "";
                })
                .catch(() => {
                    document.getElementById("infoPatio").innerText =
                        "Error consultando el contenedor";
                });
        }

        document.getElementById("btnBuscarContenedor")
            ?.addEventListener("click", buscarContenedor);

        document.getElementById("contenedorInput")
            ?.addEventListener("keypress", e => {
                if (e.key === "Enter") {
                    e.preventDefault();
                    buscarContenedor();
                }
            });
    });
</script>
