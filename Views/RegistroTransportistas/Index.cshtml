@{
    ViewData["Title"] = "Registro de Transportistas";
}

@if (TempData["Ok"] != null)
{
    <div class="alert alert-success">@TempData["Ok"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="mb-4">
        <h2 class="fw-bold mb-1">🚛 Registro de Transportistas</h2>
        <small class="text-muted">
            Registro de choferes que ingresan para retirar contenedores, furgones, planas o carreta.
        </small>
    </div>

    <!-- GRID -->
    <div class="row g-4">

        <!-- PATIO -->
        <div class="col-md-6 col-xl-4">
            <a asp-action="Patio"
               class="text-decoration-none">

                <div class="card shadow-sm h-100 border-0 card-hover">

                    <div class="card-body text-center p-4">

                        <div class="icon-box bg-primary-subtle text-primary mb-3">
                            <i class="bi bi-truck-front-fill fs-3"></i>
                        </div>

                        <h5 class="fw-bold text-primary mb-2">
                            Patio
                        </h5>

                        <p class="text-muted small mb-0">
                            Registro de choferes que retiran equipos ubicados en patio.
                        </p>

                    </div>

                </div>

            </a>
        </div>

        <!-- AGROQUIMICOS -->
        <div class="col-md-6 col-xl-4">
            <a asp-action="Agroquimicos"
               class="text-decoration-none">

                <div class="card shadow-sm h-100 border-0 card-hover">

                    <div class="card-body text-center p-4">

                        <div class="icon-box bg-success-subtle text-success mb-3">
                            <i class="bi bi-droplet-fill fs-3"></i>
                        </div>

                        <h5 class="fw-bold text-success mb-2">
                            Agroquímicos
                        </h5>

                        <p class="text-muted small mb-0">
                            Registro de choferes que retiran equipos del área de agroquímicos.
                        </p>

                    </div>

                </div>

            </a>
        </div>

        <!-- BODEGA 2000 -->
        <div class="col-md-6 col-xl-4">
            <a asp-action="Bodega2000"
               class="text-decoration-none">

                <div class="card shadow-sm h-100 border-0 card-hover">

                    <div class="card-body text-center p-4">

                        <div class="icon-box bg-warning-subtle text-warning mb-3">
                            <i class="bi bi-building-fill fs-3"></i>
                        </div>

                        <h5 class="fw-bold text-warning mb-2">
                            Bodega 2000
                        </h5>

                        <p class="text-muted small mb-0">
                            Registro de choferes que retiran equipos de Bodega 2000.
                        </p>

                    </div>

                </div>

            </a>
        </div>

        <!-- DASHBOARD GLOBAL -->
        <div class="col-md-6 col-xl-4">

            <a asp-controller="DashboardTransportistas"
               asp-action="Index"
               class="text-decoration-none">

                <div class="card shadow-sm h-100 border-0 card-hover">

                    <div class="card-body text-center p-4">

                        <div class="icon-box bg-dark-subtle text-dark mb-3">

                            <i class="bi bi-speedometer2 fs-3"></i>

                        </div>

                        <h5 class="fw-bold text-dark mb-2">
                            Dashboard Global
                        </h5>

                        <p class="text-muted small mb-0">
                            Vista consolidada de Patio, Agroquímicos y Bodega 2000 en tiempo real.
                        </p>

                    </div>

                </div>

            </a>

        </div>

    </div>

</div>

<style>
    .card-hover {
        border-radius: 16px;
        transition: all 0.25s ease;
    }

        .card-hover:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.10);
        }

    .icon-box {
        width: 60px;
        height: 60px;
        margin: 0 auto;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>