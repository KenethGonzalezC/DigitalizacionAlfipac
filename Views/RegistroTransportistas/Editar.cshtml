@model BitacoraAlfipac.Models.Entidades.RegistroTransportista

@{
    ViewData["Title"] = "Editar Registro";
}

<div class="container-fluid py-4">

    <div class="card shadow-sm">

        <div class="card-header bg-warning">

            <h4 class="mb-0">
                ✏️ Editar Registro
            </h4>

        </div>

        <div class="card-body">

            <form asp-action="Editar" method="post">

                <input asp-for="Id" type="hidden" />
                <input asp-for="Ubicacion" type="hidden" />

                <div class="row g-3">

                    <div class="col-md-4">

                        <label class="form-label">
                            Fecha y Hora
                        </label>

                        <input asp-for="FechaRegistro"
                               type="datetime-local"
                               class="form-control" />

                    </div>

                    <div class="col-md-4">

                        <label asp-for="Placa"
                               class="form-label">
                        </label>

                        <input asp-for="Placa"
                               class="form-control" />

                    </div>

                    <div class="col-md-4">

                        <label asp-for="Tipo"
                               class="form-label">
                        </label>

                        <input asp-for="Tipo"
                               class="form-control" />

                    </div>

                    <div class="col-md-6">

                        <label asp-for="NombreChofer"
                               class="form-label">
                        </label>

                        <input asp-for="NombreChofer"
                               class="form-control" />

                    </div>

                    <div class="col-md-6">

                        <label asp-for="Cliente"
                               class="form-label">
                        </label>

                        <input asp-for="Cliente"
                               class="form-control" />

                    </div>

                    <div class="col-md-6">

                        <label asp-for="DUA"
                               class="form-label">
                        </label>

                        <input asp-for="DUA"
                               class="form-control" />

                    </div>

                </div>

                <hr />

                <div class="d-flex gap-2">

                    <button type="submit"
                            class="btn btn-success">

                        <i class="bi bi-check-circle"></i>
                        Guardar Cambios

                    </button>

                    <a asp-action="Patio"
                       class="btn btn-secondary">

                        Cancelar

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}