@model BitacoraAlfipac.Models.Entidades.RegistroTransportista

@{
    ViewData["Title"] = "Editar Registro";
}

<div class="container-fluid py-4">

    <div class="card shadow-sm">

        <div class="card-header bg-warning">

            <h4 class="mb-0">
                ✏️ Editar Registro
            </h4>

        </div>

        <div class="card-body">

            <form asp-action="Editar" method="post">

                <input asp-for="Id" type="hidden" />
                <input asp-for="Ubicacion" type="hidden" />

                <div class="row g-3">

                    <div class="col-md-4">

                        <label class="form-label">
                            Fecha y Hora
                        </label>

                        <input name="FechaRegistro"
                               type="datetime-local"
                               class="form-control"
                               value="@Model.FechaRegistro.ToString("yyyy-MM-ddTHH:mm")" />

                    </div>

                    <div class="col-md-4">

                        <label asp-for="Placa"
                               class="form-label">
                        </label>

                        <input asp-for="Placa"
                               class="form-control" />

                    </div>

                    <div class="col-md-4">

                        <label asp-for="Tipo"
                               class="form-label">
                        </label>

                        <input asp-for="Tipo"
                               class="form-control" />

                    </div>

                    <div class="col-md-6">

                        <label asp-for="NombreChofer"
                               class="form-label">
                        </label>

                        <input asp-for="NombreChofer"
                               class="form-control" />

                    </div>

                    <div class="col-md-6">

                        <label asp-for="Cliente"
                               class="form-label">
                        </label>

                        <input asp-for="Cliente"
                               class="form-control" />

                    </div>

                    <div class="col-md-6">

                        <label asp-for="DUA"
                               class="form-label">
                        </label>

                        <input asp-for="DUA"
                               class="form-control" />

                    </div>

                    <hr />

                    <div class="card border-primary">

                        <div class="card-header bg-primary text-white">

                            <strong>
                                📍 Movimiento de Ubicación
                            </strong>

                        </div>

                        <div class="card-body">

                            <div class="alert alert-info mb-3">

                                Ubicación actual:
                                <strong>@Model.Ubicacion</strong>

                            </div>

                            <label class="form-label">

                                Mover transportista a:

                            </label>

                            <select name="nuevaUbicacion"
                                    class="form-select">

                                <option value="">
                                    No mover
                                </option>

                                <option value="Patio">
                                    Cargados
                                </option>

                                <option value="Vacios">
                                    Vacios
                                </option>

                                <option value="Bodega2000">
                                    Bodega 2000
                                </option>

                                <option value="Agroquimicos">
                                    Agroquímicos
                                </option>

                            </select>

                            <small class="text-muted">

                                Si selecciona una ubicación diferente,
                                el registro será trasladado al guardar.

                            </small>

                        </div>

                    </div>

                </div>

                <hr />

                <div class="d-flex gap-2">

                    <button type="submit"
                            class="btn btn-success">

                        <i class="bi bi-check-circle"></i>
                        Guardar Cambios

                    </button>

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        Cancelar

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}