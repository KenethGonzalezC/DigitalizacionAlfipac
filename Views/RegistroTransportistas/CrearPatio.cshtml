@model BitacoraAlfipac.Models.Entidades.RegistroTransportista

@{
    ViewData["Title"] = "Nuevo Registro - Patio";
}

<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="mb-4">

        <h2 class="fw-bold mb-1">
            🚛 Nuevo Registro de Transportista
        </h2>

        <small class="text-muted">
            Registro de ingreso para retiro de contenedores, furgones o plataformas ubicadas en Patio.
        </small>

    </div>

    <!-- FORMULARIO -->
    <form asp-action="CrearPatio"
          method="post"
          id="formRegistro">

        @Html.AntiForgeryToken()

        <input type="hidden"
               id="FirmaBase64"
               name="FirmaBase64" />

        <input asp-for="Ubicacion"
               type="hidden"
               value="Patio" />

        <div class="card shadow-sm border-0">

            <div class="card-header bg-primary text-white">

                <strong>
                    Información del Transportista
                </strong>

            </div>

            <div class="card-body">

                <div class="row g-3">

                    <!-- FECHA -->
                    <div class="col-md-4">

                        <label class="form-label">
                            Fecha y Hora
                        </label>

                        <input asp-for="FechaRegistro"
                               type="datetime-local"
                               class="form-control"
                               value="@Model.FechaRegistro.ToString("yyyy-MM-ddTHH:mm")" />

                    </div>

                    <!-- PLACA -->
                    <div class="col-md-4">

                        <label asp-for="Placa"
                               class="form-label">
                        </label>

                        <input asp-for="Placa"
                               class="form-control text-uppercase" />

                        <span asp-validation-for="Placa"
                              class="text-danger">
                        </span>

                    </div>                    

                    <!-- CHOFER -->
                    <div class="col-md-6">

                        <label asp-for="NombreChofer"
                               class="form-label">
                            Chofer
                        </label>

                        <input asp-for="NombreChofer"
                               class="form-control" />

                        <span asp-validation-for="NombreChofer"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- CLIENTE -->
                    <div class="col-md-6">

                        <label asp-for="Cliente"
                               class="form-label">
                        </label>

                        <input asp-for="Cliente"
                               class="form-control" />

                        <span asp-validation-for="Cliente"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- DUA -->
                    <div class="col-md-6">

                        <label asp-for="DUA"
                               class="form-label">
                        </label>

                        <input asp-for="DUA"
                               class="form-control text-uppercase" />

                        <span asp-validation-for="DUA"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- TIPO -->
                    <div class="col-md-4">

                        <label asp-for="Tipo"
                               class="form-label">
                            Tipo
                        </label>

                        <input asp-for="Tipo"
                               class="form-control"
                               maxlength="50"
                               placeholder="Contenedor, Furgon, Plana" />

                        <span asp-validation-for="Tipo"
                              class="text-danger">
                        </span>

                    </div>

                </div>

            </div>

        </div>

        <!-- FIRMA -->
        <div class="card shadow-sm border-0 mt-4">

            <div class="card-header bg-success text-white">

                <strong>
                    Firma del Transportista
                </strong>

            </div>

            <div class="card-body">

                <div class="alert alert-info mb-3">

                    El chofer debe firmar dentro del área indicada antes de guardar el registro.

                </div>

                <div class="firma-container">

                    <canvas id="signature-pad">
                    </canvas>

                </div>

                <div id="firmaError"
                     class="text-danger fw-bold mt-2 d-none">

                    Debe capturar una firma antes de guardar.

                </div>

                <div class="mt-3 d-flex gap-2">

                    <button type="button"
                            id="btnLimpiarFirma"
                            class="btn btn-outline-secondary">

                        <i class="bi bi-eraser"></i>
                        Limpiar Firma

                    </button>

                </div>

            </div>

        </div>

        <!-- BOTONES -->
        <div class="mt-4 d-flex gap-2">

            <button type="submit"
                    class="btn btn-success">

                <i class="bi bi-save"></i>
                Guardar Registro

            </button>

            <a asp-action="Patio"
               class="btn btn-secondary">

                <i class="bi bi-arrow-left"></i>
                Regresar

            </a>

        </div>

    </form>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script src="~/js/firma-digital.js"></script>

}

<style>

    .firma-container {
    width: 100%;
    border: 2px dashed #ced4da;
    border-radius: 12px;
    overflow: hidden;
    background: white;
    }

    #signature-pad {
    width: 100%;
    height: 420px;
    display: block;
    touch-action: none;
    cursor: crosshair;
    background-color: white;
    }

</style>