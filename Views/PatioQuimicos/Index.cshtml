@model IEnumerable<BitacoraAlfipac.Models.Entidades.PatioQuimicos>

<h2>Inventario de Contenedores</h2>

<div>
    <a asp-controller="Inventario"
           asp-action="InventarioGeneral"
           class="btn btn-dark mb-3">
        📊 Ver Inventario General
    </a>
</div>

<div>
    <a asp-controller="BitacoraIngresos"
           asp-action="Vehiculos"
           class="btn btn-outline-primary">
        🚗 Vehículos en almacén
    </a>
</div>

<h5></h5>

<div class="row mb-4">
    <div class="col">
        <a asp-controller="Inventario"
               asp-action="Index"
               class="btn btn-outline-primary w-100">
            Inventario
        </a>
    </div>

    <div class="col">
        <a asp-controller="Patio1"
               asp-action="Index"
               class="btn btn-outline-info w-100">
            Patio 1
        </a>
    </div>

    <div class="col">
        <a asp-controller="Patio2"
               asp-action="Index"
               class="btn btn-outline-success w-100">
            Patio 2
        </a>
    </div>

    <div class="col">
        <a asp-controller="Anden2000"
               asp-action="Index"
               class="btn btn-outline-warning w-100">
            Andén 2000
        </a>
    </div>
</div>

<form id="formBusquedaGlobal">
    <div class="row align-items-end">
        <div class="col-md-4">
            <input name="contenedor"
                   class="form-control"
                   placeholder="Buscar contenedor..." />
        </div>

        <div class="col-md-4 d-flex gap-2">
            <button type="submit"
                    class="btn btn-primary flex-fill">
                Buscar
            </button>

            <a asp-action="Index"
                   class="btn btn-secondary flex-fill">
                Limpiar
            </a>
        </div>
    </div>
</form>

<div class="my-3 d-flex gap-2">

    <form asp-action="LimpiarPatio"
          method="post"
          onsubmit="return confirm('¿Seguro que desea limpiar TODO el patio?');">

        <button class="btn btn-danger">
            🧹 Limpiar patio
        </button>
    </form>

    <button class="btn btn-warning"
            data-bs-toggle="modal"
            data-bs-target="#modalExportar">
        📄 Exportar Inventario
    </button>

    <button id="btnGuardarOrden"
            class="btn btn-success">
        💾 Guardar orden
    </button>

</div>

<!-- PANEL TRASLADO QUÍMICOS -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-danger text-dark">
        <h5 class="mb-0">🚚 Traslado rápido de contenedores</h5>
        <small>Arrastre el ☰ hacia el destino</small>
    </div>

    <div class="card-body">
        <div class="row g-3">

            <div class="col-md-3">
                <div class="drop-box border rounded p-4 text-center bg-light"
                     data-destino="SinAsignar">
                    📦 Sin asignar
                </div>
            </div>

            <div class="col-md-3">
                <div class="drop-box border rounded p-4 text-center bg-light"
                     data-destino="Patio1">
                    📍 Patio 1
                </div>
            </div>

            <div class="col-md-3">
                <div class="drop-box border rounded p-4 text-center bg-light"
                     data-destino="Patio2">
                    🚛 Patio 2
                </div>
            </div>

            <div class="col-md-3">
                <div class="drop-box border rounded p-4 text-center bg-light"
                     data-destino="Anden2000">
                    🏗️ Andén 2000
                </div>
            </div>

        </div>
    </div>
</div>

<h4 class="mt-4">Patio Químicos</h4>

<!-- MODAL EXPORTAR -->
<div class="modal fade" id="modalExportar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <form method="post">

                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        Datos de exportación
                    </h5>

                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <div class="modal-body">

                    <input name="nombre"
                           class="form-control mb-2"
                           placeholder="Responsable"
                           required />

                    <input type="date"
                           name="fecha"
                           class="form-control mb-2"
                           required />

                    <input name="turno"
                           class="form-control"
                           placeholder="Turno"
                           required />

                </div>

                <div class="modal-footer d-flex gap-2">

                    <button formaction="/PatioQuimicos/ExportarPDF"
                            class="btn btn-danger flex-fill">
                        PDF
                    </button>

                    <button formaction="/PatioQuimicos/ExportarExcel"
                            class="btn btn-success flex-fill">
                        Excel
                    </button>

                    <button formaction="/PatioQuimicos/ExportarCSV"
                            class="btn btn-primary flex-fill">
                        CSV
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

<table class="table table-sm table-bordered">
    <thead>
        <tr>
            <th style="width:50px;">Mover</th>
            <th>Contenedor</th>
            <th>Marchamos</th>
            <th>Tamaño</th>
            <th>Chasis</th>
            <th>Transportista</th>
            <th>Cliente</th>
            <th>Estado</th>
            <th>Confirmar</th>
            <th>Ubicación</th>
            <th>Acción Mover</th>
        </tr>
    </thead>

    <tbody id="tablaOrden">
        @foreach (var c in Model)
        {
            <tr data-id="@c.Id">
                <form method="post">

                    <input type="hidden" name="id" value="@c.Id" />

                    <td class="text-center align-middle">
                        <span class="handle fw-bold fs-5"
                              style="cursor:grab; user-select:none;">
                            ☰
                        </span>
                    </td>

                    <td class="contenedor-nombre">@c.Contenedor</td>

                    <td>
                        <input name="marchamos"
                               value="@c.Marchamos"
                               class="form-control form-control-sm" />
                    </td>

                    <td>@c.Tamano</td>

                    <td>
                        <input name="chasis"
                               value="@c.Chasis"
                               class="form-control form-control-sm" />
                    </td>

                    <td>
                        <input name="transportista"
                               value="@c.Transportista"
                               class="form-control form-control-sm" />
                    </td>

                    <td>
                        <input name="cliente"
                               value="@c.Cliente"
                               class="form-control form-control-sm" />
                    </td>

                    <td>
                        <select name="estadoCarga"
                                class="form-select form-select-sm">

                            <option value="Vacio"
                                    selected="@(c.EstadoCarga == "Vacio")">
                                Vacío
                            </option>

                            <option value="Cargado"
                                    selected="@(c.EstadoCarga == "Cargado")">
                                Cargado
                            </option>

                        </select>
                    </td>

                    <td class="text-center">
                        <button type="submit"
                                formaction="@Url.Action("ConfirmarEdicion", "PatioQuimicos")"
                                class="btn btn-sm btn-primary">
                            ✔
                        </button>
                    </td>

                    <td>
                        <select name="destino"
                                class="form-select form-select-sm">
                            <option value="">No mover</option>
                            <option value="SinAsignar">Sin asignar</option>
                            <option value="Patio1">Patio 1</option>
                            <option value="Patio2">Patio 2</option>
                            <option value="Anden2000">Andén 2000</option>
                            <option value="PatioQuimicos">Patio Químicos</option>
                        </select>
                    </td>

                    <td>
                        <button type="submit"
                                formaction="@Url.Action("MoverDesdePatioQuimicos", "PatioQuimicos")"
                                class="btn btn-sm btn-success">
                            Mover
                        </button>
                    </td>

                </form>
            </tr>
        }
    </tbody>
</table>

<!-- MODAL BUSQUEDA -->
<div class="modal fade" id="modalBusquedaGlobal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    Resultado de búsqueda
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body"
                 id="contenidoModalBusqueda">
            </div>

        </div>
    </div>
</div>

@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

        // DRAG & DROP SOLO HANDLE
        let filaSeleccionada = null;

        new Sortable(document.getElementById("tablaOrden"), {
        animation: 150,
        handle: ".handle",
        ghostClass: "table-warning",

        onStart: function (evt) {
        filaSeleccionada = evt.item;
        },

        onEnd: function () {
        setTimeout(() => filaSeleccionada = null, 150);
        }
        });

        // ===============================
        // DROP EN BOXES
        // ===============================
        document.querySelectorAll(".drop-box").forEach(box => {

        box.addEventListener("dragover", function (e) {
        e.preventDefault();
        this.classList.add("bg-success", "text-white");
        });

        box.addEventListener("dragleave", function () {
        this.classList.remove("bg-success", "text-white");
        });

        box.addEventListener("drop", function (e) {

        e.preventDefault();
        this.classList.remove("bg-success", "text-white");

        if (!filaSeleccionada) return;

        const id = filaSeleccionada.dataset.id;
        const destino = this.dataset.destino;

        const nombre =
        filaSeleccionada.querySelector(".contenedor-nombre").innerText;

        if (!confirm(`¿Mover ${nombre} a ${destino}?`))
        return;

        const data = new URLSearchParams();
        data.append("id", id);
        data.append("destino", destino);

        fetch('/PatioQuimicos/MoverDesdePatioQuimicos', {
        method: 'POST',
        headers: {
        'Content-Type': 'application/x-www-form-urlencoded'
        },
        body: data.toString()
        })
        .then(r => location.reload());

        });

        });

        // GUARDAR ORDEN
        document.getElementById("btnGuardarOrden")
        .addEventListener("click", function () {

        let lista = [];

        document.querySelectorAll("#tablaOrden tr")
        .forEach((fila, index) => {

        lista.push({
        id: parseInt(fila.dataset.id),
        orden: index + 1
        });

        });

        fetch('/PatioQuimicos/GuardarOrden', {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json'
        },
        body: JSON.stringify(lista)
        })
        .then(r => r.json())
        .then(res => {

        if (res.success) {
        alert("Orden guardado correctamente");
        location.reload();
        }

        });

        });

        // BUSQUEDA GLOBAL
        document.getElementById("formBusquedaGlobal")
        .addEventListener("submit", function (e) {

        e.preventDefault();

        const contenedor =
        this.querySelector("input[name='contenedor']").value;

        fetch(`/Inventario/BuscarGlobal?contenedor=${contenedor}`)
        .then(r => r.text())
        .then(html => {

        document.getElementById("contenidoModalBusqueda").innerHTML = html;

        new bootstrap.Modal(
        document.getElementById("modalBusquedaGlobal")
        ).show();

        });

        });

        // FORMULARIOS MODAL
        document.addEventListener("submit", function (e) {

        const form = e.target.closest("#modalBusquedaGlobal form");

        if (!form) return;

        e.preventDefault();

        fetch(form.action, {
        method: "POST",
        body: new FormData(form)
        })
        .then(r => r.json())
        .then(res => {

        if (res.success) {

        bootstrap.Modal.getInstance(
        document.getElementById("modalBusquedaGlobal")
        ).hide();

        location.reload();
        }

        });

        });

        });
    </script>
}