@model IEnumerable<BitacoraAlfipac.Models.Entidades.Visita>

@{
    ViewData["Title"] = "Registro de Visitas";
}

@if (TempData["Ok"] != null)
{
    <div class="alert alert-success">@TempData["Ok"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="mb-4">
        <h2 class="fw-bold mb-1">🪪 Registro de Visitas</h2>

        <small class="text-muted">
            Control de ingreso de visitantes mediante registro manual o lectura de cédula.
        </small>
    </div>

    <!-- ACCIONES -->
    <div class="row g-4 mb-4">

        <!-- ESCANEAR -->
        <div class="col-md-6">

            <a href="#"
               class="text-decoration-none"
               data-bs-toggle="modal"
               data-bs-target="#modalEscaner">

                <div class="card shadow-sm h-100 border-0 card-hover">

                    <div class="card-body text-center p-4">

                        <div class="icon-box bg-primary-subtle text-primary mb-3">
                            <i class="bi bi-camera-fill fs-3"></i>
                        </div>

                        <h5 class="fw-bold text-primary mb-2">
                            Escanear Cédula
                        </h5>

                        <p class="text-muted small mb-0">
                            Utilizar la cámara para leer automáticamente los datos del visitante.
                        </p>

                    </div>

                </div>

            </a>

        </div>

        <!-- MANUAL -->
        <div class="col-md-6">

            <a href="#"
               class="text-decoration-none"
               data-bs-toggle="modal"
               data-bs-target="#modalFormulario">

                <div class="card shadow-sm h-100 border-0 card-hover">

                    <div class="card-body text-center p-4">

                        <div class="icon-box bg-success-subtle text-success mb-3">
                            <i class="bi bi-pencil-square fs-3"></i>
                        </div>

                        <h5 class="fw-bold text-success mb-2">
                            Registro Manual
                        </h5>

                        <p class="text-muted small mb-0">
                            Registrar una visita ingresando los datos manualmente.
                        </p>

                    </div>

                </div>

            </a>

        </div>

    </div>

    <!-- TABLA -->
    <div class="card shadow-sm border-0">

        <div class="card-header bg-white">
            <h5 class="mb-0 fw-bold">
                Visitas del Día
            </h5>
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-light">

                        <tr>
                            <th>Hora</th>
                            <th>Cédula</th>
                            <th>Visitante</th>
                            <th>Persona Visitada</th>
                            <th>Departamento</th>
                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        @item.FechaIngreso.ToString("HH:mm")
                                    </td>

                                    <td>
                                        @item.NumeroCedula
                                    </td>

                                    <td>
                                        @item.NombreCompletoVisitante
                                    </td>

                                    <td>
                                        @item.PersonaVisita
                                    </td>

                                    <td>
                                        @item.Departamento
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    No hay visitas registradas hoy.
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<!-- MODAL ESCANER -->
<div class="modal fade"
     id="modalEscaner"
     tabindex="-1">

    <div class="modal-dialog modal-xl">

        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">
                    Escanear Cédula
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">

                <div class="row">

                    <div class="col-12">

                        <div class="alert alert-info">

                            Coloque la cédula frente a la cámara.

                        </div>

                        <video id="videoCedula"
                               class="w-100 border rounded shadow-sm"
                               autoplay
                               playsinline>
                        </video>

                        <div class="mt-3">

                            <div id="estadoEscaner"
                                 class="alert alert-secondary">

                                Esperando código PDF417...

                            </div>

                        </div>

                    </div>

                </div>

                <div class="mt-3 text-center">

                    <button type="button"
                            id="btnCapturarCedula"
                            class="btn btn-primary">

                        <i class="bi bi-camera-fill"></i>
                        Capturar

                    </button>

                </div>

                <hr />

                <div id="previewContainer"
                     style="display:none;">

                    <h6 class="fw-bold">
                        Vista previa
                    </h6>

                    <img id="previewCedula"
                         class="img-fluid border rounded shadow-sm" />

                </div>

                <canvas id="canvasCedula"
                        style="display:none;">
                </canvas>

            </div>

        </div>

    </div>

</div>

<!-- MODAL FORMULARIO -->
<div class="modal fade"
     id="modalFormulario"
     tabindex="-1">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Nueva Visita
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <div id="contenedorFormulario">
                </div>

            </div>

        </div>

    </div>

</div>

<style>

    .card-hover {
        border-radius: 16px;
        transition: all 0.25s ease;
    }

        .card-hover:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.10);
        }

    .icon-box {
        width: 60px;
        height: 60px;
        margin: 0 auto;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    #videoCedula {
        min-height: 450px;
        background-color: #000;
        object-fit: cover;
    }

</style>

@section Scripts {

    <script>

        let cameraStream = null;
        let desdeOCR = false;

        // =========================
        // FORMULARIO MANUAL
        // =========================

        $('#modalFormulario').on('shown.bs.modal', function () {

            // 🚨 SOLO cargar formulario si NO viene del OCR
            if (desdeOCR) return;

            $("#contenedorFormulario").load(
                '@Url.Action("Formulario", "Visitas")'
            );

        });

        // =========================
        // ABRIR ESCANER
        // =========================

        $('#modalEscaner').on('shown.bs.modal', async function () {

            try {

                document.getElementById('estadoEscaner').className =
                    'alert alert-info';

                document.getElementById('estadoEscaner').innerHTML =
                    'Inicializando cámara...';

                cameraStream =
                    await navigator.mediaDevices.getUserMedia({
                        video: {
                            facingMode: { ideal: "environment" },
                            width: { ideal: 2560 },
                            height: { ideal: 1440 }
                        },
                        audio: false
                    });

                const video =
                    document.getElementById('videoCedula');

                video.srcObject = cameraStream;

                await video.play();

                video.onloadedmetadata = () => {

                    document.getElementById('estadoEscaner').className =
                        'alert alert-success';

                    document.getElementById('estadoEscaner').innerHTML =
                        `Cámara lista (${video.videoWidth} x ${video.videoHeight})`;
                };

            }
            catch (error) {

                console.error(error);

                document.getElementById('estadoEscaner').className =
                    'alert alert-danger';

                document.getElementById('estadoEscaner').innerHTML =
                    'No fue posible acceder a la cámara.';
            }

        });

        // =========================
        // CERRAR ESCANER
        // =========================

        $('#modalEscaner').on('hidden.bs.modal', function () {

            if (cameraStream) {
                cameraStream.getTracks().forEach(track => track.stop());
                cameraStream = null;
            }

            document.getElementById('previewContainer').style.display = 'none';

            document.getElementById('estadoEscaner').className =
                'alert alert-secondary';

            document.getElementById('estadoEscaner').innerHTML =
                'Esperando OCR...';

        });

        // =========================
        // CAPTURAR + OCR
        // =========================

        document
            .getElementById('btnCapturarCedula')
            .addEventListener('click', async function () {

                try {

                    const video =
                        document.getElementById('videoCedula');

                    const canvas =
                        document.getElementById('canvasCedula');

                    const ctx =
                        canvas.getContext('2d');

                    canvas.width = video.videoWidth;
                    canvas.height = video.videoHeight;

                    ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

                    const imageData =
                        canvas.toDataURL('image/jpeg', 1.0);

                    document.getElementById('previewCedula').src = imageData;
                    document.getElementById('previewContainer').style.display = 'block';

                    document.getElementById('estadoEscaner').className =
                        'alert alert-warning';

                    document.getElementById('estadoEscaner').innerHTML =
                        'Procesando OCR...';

                    const response =
                        await fetch('/Visitas/LeerCedula', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ imagenBase64: imageData })
                        });

                    const data = await response.json();

                    console.log("OCR RESULTADO:", data);

                    if (!data.success) {

                        document.getElementById('estadoEscaner').className =
                            'alert alert-danger';

                        document.getElementById('estadoEscaner').innerHTML =
                            data.mensaje;

                        return;
                    }

                    document.getElementById('estadoEscaner').className =
                        'alert alert-success';

                    document.getElementById('estadoEscaner').innerHTML =
                        data.mensaje;

                    // =========================
                    // ACTIVAR MODO OCR
                    // =========================

                    desdeOCR = true;

                    bootstrap.Modal
                        .getInstance(document.getElementById('modalEscaner'))
                        .hide();

                    // =========================
                    // CARGAR FORMULARIO ESCANEADO
                    // =========================

                    $("#contenedorFormulario").load(
                        '/Visitas/FormularioEscaneado?cedula=' +
                        encodeURIComponent(data.cedula || '') +
                        '&nombre=' +
                        encodeURIComponent(data.nombre || ''),
                        function () {

                            const modal =
                                new bootstrap.Modal(
                                    document.getElementById('modalFormulario')
                                );

                            modal.show();

                            // fallback por seguridad
                            setTimeout(() => {

                                const cedulaInput =
                                    document.querySelector('[name="NumeroCedula"]');

                                const nombreInput =
                                    document.querySelector('[name="NombreCompletoVisitante"]');

                                if (cedulaInput) cedulaInput.value = data.cedula || '';
                                if (nombreInput) nombreInput.value = data.nombre || '';

                                // 🔥 desactivar flag después de cargar
                                desdeOCR = false;

                            }, 200);

                        }
                    );

                }
                catch (error) {

                    console.error(error);

                    document.getElementById('estadoEscaner').className =
                        'alert alert-danger';

                    document.getElementById('estadoEscaner').innerHTML =
                        'Error procesando OCR.';
                }

            });

    </script>

}