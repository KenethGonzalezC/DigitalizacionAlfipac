@{
    ViewData["Title"] = "Inicio";
}

<div class="dashboard">

    <!-- HEADER -->
    <div class="mb-4">
        <h2 class="fw-bold">Panel principal</h2>
        <p class="text-muted mb-0">
            Accesos rápidos al sistema
        </p>
    </div>

    <!-- ACCESOS PRINCIPALES -->
    <div class="row g-4 mb-4">

        @if (User.IsInRole("Administrador") || User.IsInRole("Digitador") || User.IsInRole("Patio"))
        {
            <div class="col-md-6 col-lg-4">
                <a asp-controller="Inventario" asp-action="Index" class="dashboard-link">
                    <div class="card dashboard-main-card">
                        <div class="card-body">
                            <i class="bi bi-box-seam dashboard-icon"></i>
                            <h5>Inventario</h5>
                            <p class="text-muted">Contenedores almacenados</p>
                        </div>
                    </div>
                </a>
            </div>
        }

        @if (User.IsInRole("Administrador") || User.IsInRole("Digitador"))
        {
            <div class="col-md-6 col-lg-4">
                <a asp-controller="BitacoraIngresos" asp-action="Index" class="dashboard-link">
                    <div class="card dashboard-main-card">
                        <div class="card-body">
                            <i class="bi bi-arrow-down-circle dashboard-icon text-success"></i>
                            <h5>Ingresos</h5>
                            <p class="text-muted">Registrar entradas</p>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-6 col-lg-4">
                <a asp-controller="BitacoraDespachos" asp-action="Index" class="dashboard-link">
                    <div class="card dashboard-main-card">
                        <div class="card-body">
                            <i class="bi bi-arrow-up-circle dashboard-icon text-danger"></i>
                            <h5>Despachos</h5>
                            <p class="text-muted">Registrar salidas</p>
                        </div>
                    </div>
                </a>
            </div>
        }

    </div>

    <!-- OPERACIONES -->
    <div class="mb-3">
        <h5 class="fw-semibold">Operaciones</h5>
    </div>

    <div class="row g-3">

        <div class="col-md-6 col-lg-3">
            <a asp-controller="Temperaturas" asp-action="Index" class="dashboard-link">
                <div class="card dashboard-small-card">
                    <div class="card-body">
                        <i class="bi bi-thermometer-half"></i>
                        <span>Refrigerados</span>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-3">
            <a asp-controller="HistorialContenedores" asp-action="Index" class="dashboard-link">
                <div class="card dashboard-small-card">
                    <div class="card-body">
                        <i class="bi bi-clock-history"></i>
                        <span>Historial</span>
                    </div>
                </div>
            </a>
        </div>

        @if (User.IsInRole("Administrador") || User.IsInRole("Digitador"))
        {
            <div class="col-md-6 col-lg-3">
                <a asp-controller="Bitacora" asp-action="Index" class="dashboard-link">
                    <div class="card dashboard-small-card">
                        <div class="card-body">
                            <i class="bi bi-journal-text"></i>
                            <span>Bitácora</span>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-6 col-lg-3">
                <a asp-controller="Datos" asp-action="Index" class="dashboard-link">
                    <div class="card dashboard-small-card">
                        <div class="card-body">
                            <i class="bi bi-database"></i>
                            <span>Datos</span>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-6 col-lg-3">
                <a asp-controller="ActasPermanencias" asp-action="Index" class="dashboard-link">
                    <div class="card dashboard-small-card">
                        <div class="card-body">
                            <i class="bi bi-file-earmark-text"></i>
                            <span>Actas</span>
                        </div>
                    </div>
                </a>
            </div>
        }

        @if (User.IsInRole("Administrador"))
        {
            <div class="col-md-6 col-lg-3">
                <a asp-controller="Usuarios" asp-action="Index" class="dashboard-link">
                    <div class="card dashboard-small-card border-danger">
                        <div class="card-body text-danger">
                            <i class="bi bi-people"></i>
                            <span>Usuarios</span>
                        </div>
                    </div>
                </a>
            </div>
        }

    </div>

</div>