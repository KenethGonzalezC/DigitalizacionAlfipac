@model List<BitacoraAlfipac.Models.Entidades.Vacio>

@{
    ViewData["Title"] = "Historial de Vacíos";
}

@if (TempData["Ok"] != null)
{
    <div class="alert alert-success">@TempData["Ok"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div >

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">

        <div>
            <h3 class="mb-0">📚 Historial de Reportes Vacíos</h3>
            <small class="text-muted">Consulta y administración de reportes generados</small>
        </div>

        <div class="d-flex gap-2">

            <button class="btn btn-success"
                    data-bs-toggle="modal"
                    data-bs-target="#modalExcel">
                📗 Exportar Excel
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                ← Volver
            </a>

        </div>

    </div>

    <!-- ================= FILTRO ================= -->
    <form method="get" class="card shadow-sm p-3 mb-3">

        <div class="row g-3 align-items-end">

            <div class="col-md-3">
                <label class="form-label">Fecha</label>
                <input type="date"
                       name="fecha"
                       class="form-control" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Contenedor</label>
                <input type="text"
                       name="contenedor"
                       value="@Context.Request.Query["contenedor"]"
                       class="form-control" />
            </div>

            <div class="col-md-2 d-grid">
                <label class="form-label invisible">Buscar</label>
                <button type="submit" class="btn btn-primary">
                    🔎 Buscar
                </button>
            </div>

            <div class="col-md-2 d-grid">
                <label class="form-label invisible">Hoy</label>
                <a asp-action="Historial"
                       class="btn btn-outline-secondary">
                    Hoy
                </a>
            </div>

        </div>

    </form>

    <!-- ================= TABLA ================= -->
    <div class="card shadow-sm">

        <div class="card-header bg-light">
            <strong>Registros de historial</strong>
        </div>

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-dark">
                    <tr>
                        <th>Fecha</th>
                        <th>Hora</th>
                        <th>Contenedor</th>
                        <th>Cliente</th>
                        <th>Transportista</th>
                        <th>Consecutivo</th>
                        <th>Usuario</th>
                        <th class="text-center">PDF</th>
                        <th class="text-center">Editar</th>
                        <th class="text-center">Eliminar</th>
                    </tr>
                </thead>

                <tbody>

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-4">
                                No hay registros para esta fecha
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@item.Fecha.ToString("HH:mm")</td>

                                <td class="fw-semibold">@item.Contenedor</td>
                                <td>@item.Cliente</td>
                                <td>@item.Transportista</td>

                                <td>
                                    <span class="badge bg-primary">
                                        @item.Consecutivo
                                    </span>
                                </td>

                                <td>@item.Usuario</td>

                                <td class="text-center">
                                    <a asp-action="Reimprimir"
                                           asp-route-id="@item.Id"
                                           target="_blank"
                                           class="btn btn-sm btn-outline-primary">
                                        PDF
                                    </a>
                                </td>

                                <td class="text-center">
                                    <button type="button"
                                            class="btn btn-sm btn-warning btnEditarVacio"
                                            data-id="@item.Id"
                                            data-fecha="@item.Fecha.ToString("yyyy-MM-ddTHH:mm")"
                                            data-contenedor="@item.Contenedor"
                                            data-cliente="@item.Cliente"
                                            data-transportista="@item.Transportista"
                                            data-consecutivo="@item.Consecutivo"
                                            data-usuario="@item.Usuario">
                                        ✏️
                                    </button>
                                </td>

                                <td class="text-center">
                                    <form asp-action="EliminarRegistroVacio" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />

                                        <button class="btn btn-sm btn-danger">
                                            🗑
                                        </button>
                                    </form>
                                </td>

                            </tr>
                        }
                    }

                </tbody>

            </table>

        </div>
    </div>

</div>

<!-- ================= MODAL EXPORT EXCEL ================= -->
<div class="modal fade" id="modalExcel" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <form asp-action="ExportarHistorialExcel" method="post">

                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">📗 Exportar historial</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label>Fecha inicio</label>
                            <input type="date" name="fechaInicio" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label>Fecha fin</label>
                            <input type="date" name="fechaFin" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label>Hora inicio</label>
                            <input type="time" name="horaInicio" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label>Hora fin</label>
                            <input type="time" name="horaFin" class="form-control" />
                        </div>

                    </div>

                    <hr />
                    <small class="text-muted">
                        Si no defines horas, se exporta el rango completo del día.
                    </small>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button class="btn btn-success">
                        📥 Descargar
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- ================= MODAL EDITAR ================= -->
<div class="modal fade" id="modalEditarVacio" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <form asp-action="EditarHistorial" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" id="editOrigen" name="origen" />

                <div class="modal-header bg-warning">
                    <h5 class="modal-title">Editar reporte de vacío</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input type="hidden" id="editId" name="Id" />

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label>Fecha</label>
                            <input type="datetime-local" id="editFecha" name="Fecha" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label>Consecutivo</label>
                            <input type="text" id="editConsecutivo" name="Consecutivo" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label>Contenedor</label>
                            <input type="text" id="editContenedor" name="Contenedor" class="form-control" readonly />
                        </div>

                        <div class="col-md-6">
                            <label>Cliente</label>
                            <input type="text" id="editCliente" name="Cliente" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label>Transportista</label>
                            <input type="text" id="editTransportista" name="Transportista" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label>Usuario</label>
                            <input type="text" id="editUsuario" name="Usuario" class="form-control" />
                        </div>

                    </div>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-success">Guardar</button>
                </div>

            </form>

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        document.querySelectorAll(".btnEditarVacio").forEach(btn => {

            btn.addEventListener("click", function () {

                document.getElementById("editOrigen").value = "Historial";

                document.getElementById("editId").value = this.dataset.id;
                document.getElementById("editFecha").value = this.dataset.fecha;
                document.getElementById("editConsecutivo").value = this.dataset.consecutivo;
                document.getElementById("editContenedor").value = this.dataset.contenedor;
                document.getElementById("editCliente").value = this.dataset.cliente;
                document.getElementById("editTransportista").value = this.dataset.transportista;
                document.getElementById("editUsuario").value = this.dataset.usuario;

                var modal = new bootstrap.Modal(
                    document.getElementById("modalEditarVacio")
                );

                modal.show();
            });

        });

    });
</script>