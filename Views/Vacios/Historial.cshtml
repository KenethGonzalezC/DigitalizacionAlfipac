@model List<BitacoraAlfipac.Models.Entidades.Vacio>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>📚 Historial Reportes Vacíos</h3>

        <a asp-action="Index" class="btn btn-secondary">
            ← Volver
        </a>
    </div>

    <div>
        <!-- EXPORTAR -->
        <button class="btn btn-success"
                data-bs-toggle="modal"
                data-bs-target="#modalExcel">
            📗 Exportar Excel
        </button>
    </div>

    <h5></h5>

    <!-- FILTRO -->
    <form method="get" class="card p-3 mb-3 shadow-sm">

        <div class="row g-2 align-items-end">

            <div class="col-md-3">
                <label>Fecha</label>
                <input type="date"
                       name="fecha"
                       value="@ViewBag.Fecha"
                       class="form-control" />
            </div>

            <div class="col-md-2">
                <button class="btn btn-primary w-100">
                    Buscar
                </button>
            </div>

            <div class="col-md-2">
                <a asp-action="Historial"
                       class="btn btn-outline-secondary w-100">
                    Hoy
                </a>
            </div>

        </div>

    </form>

    <!-- TABLA -->
    <div class="card shadow-sm p-3">

        <table class="table table-bordered table-striped align-middle">

            <thead class="table-dark">
                <tr>
                    <th>Fecha</th>
                    <th>Hora</th>
                    <th>Contenedor</th>
                    <th>Cliente</th>
                    <th>Transportista</th>
                    <th>Consecutivo</th>
                    <th>Usuario</th>
                </tr>
            </thead>

            <tbody>

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">
                            No hay registros para esta fecha
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@item.Fecha.ToString("HH:mm")</td>
                            <td>@item.Contenedor</td>
                            <td>@item.Cliente</td>
                            <td>@item.Transportista</td>
                            <td class="fw-bold text-primary">
                                @item.Consecutivo
                            </td>
                            <td>@item.Usuario</td>
                        </tr>
                    }
                }

            </tbody>

        </table>

    </div>

</div>

<!-- ===================================================== -->
<!-- MODAL EXPORTAR EXCEL -->
<!-- ===================================================== -->
<div class="modal fade" id="modalExcel" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <form asp-action="ExportarHistorialExcel" method="post">

                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">
                        📗 Exportar Historial a Excel
                    </h5>

                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <div class="modal-body">

                    <div class="row g-3">

                        <!-- FECHA INICIO -->
                        <div class="col-md-6">
                            <label>Fecha Inicio</label>
                            <input type="date"
                                   name="fechaInicio"
                                   class="form-control"
                                   required />
                        </div>

                        <!-- FECHA FIN -->
                        <div class="col-md-6">
                            <label>Fecha Fin</label>
                            <input type="date"
                                   name="fechaFin"
                                   class="form-control"
                                   required />
                        </div>

                        <!-- HORA INICIO -->
                        <div class="col-md-6">
                            <label>Hora Inicio</label>
                            <input type="time"
                                   name="horaInicio"
                                   class="form-control" />
                        </div>

                        <!-- HORA FIN -->
                        <div class="col-md-6">
                            <label>Hora Fin</label>
                            <input type="time"
                                   name="horaFin"
                                   class="form-control" />
                        </div>

                    </div>

                    <hr />

                    <small class="text-muted">
                        Si no seleccionas horas, se exportará todo el rango de fechas.
                    </small>

                </div>

                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button class="btn btn-success">
                        📥 Descargar Excel
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>