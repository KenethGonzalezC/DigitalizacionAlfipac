@model List<BitacoraAlfipac.Models.Entidades.Vacio>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>📚 Historial Reportes Vacíos</h3>

        <a asp-action="Index" class="btn btn-secondary">
            ← Volver
        </a>
    </div>

    <div>
        <!-- EXPORTAR -->
        <button class="btn btn-success"
                data-bs-toggle="modal"
                data-bs-target="#modalExcel">
            📗 Exportar Excel
        </button>
    </div>

    <h5></h5>

    <!-- FILTRO -->
    <form method="get" class="card p-3 mb-3 shadow-sm">

        <div class="row g-2 align-items-end">

            <div class="col-md-3">
                <label>Fecha</label>
                <input type="date"
                       name="fecha"
                       value="@ViewBag.Fecha"
                       class="form-control" />
            </div>

            <div class="col-md-2">
                <button class="btn btn-primary w-100">
                    Buscar
                </button>
            </div>

            <div class="col-md-2">
                <a asp-action="Historial"
                       class="btn btn-outline-secondary w-100">
                    Hoy
                </a>
            </div>

        </div>

    </form>

    <!-- TABLA -->
    <div class="card shadow-sm p-3">

        <table class="table table-bordered table-striped align-middle">

            <thead class="table-dark">
                <tr>
                    <th>Fecha</th>
                    <th>Hora</th>
                    <th>Contenedor</th>
                    <th>Cliente</th>
                    <th>Transportista</th>
                    <th>Consecutivo</th>
                    <th>Usuario</th>
                    <th>Reimprimir</th>
                    <th>Editar</th>
                    <th>Eliminar</th>
                </tr>
            </thead>

            <tbody>

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">
                            No hay registros para esta fecha
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@item.Fecha.ToString("HH:mm")</td>
                            <td>@item.Contenedor</td>
                            <td>@item.Cliente</td>
                            <td>@item.Transportista</td>
                            <td class="fw-bold text-primary">
                                @item.Consecutivo
                            </td>
                            <td>@item.Usuario</td>
                            <td class="text-center">

                                <!-- REIMPRIMIR PDF -->
                                <a asp-action="Reimprimir"
                                       asp-route-id="@item.Id"
                                       target="_blank"
                                       class="btn btn-sm btn-primary">
                                    PDF
                                </a>
                            </td>
                            <td>
                                <!-- EDITAR -->
                                <button type="button"
                                        class="btn btn-sm btn-warning btnEditarVacio"
                                        data-id="@item.Id"
                                        data-fecha="@item.Fecha.ToString("yyyy-MM-ddTHH:mm")"
                                        data-contenedor="@item.Contenedor"
                                        data-cliente="@item.Cliente"
                                        data-transportista="@item.Transportista"
                                        data-consecutivo="@item.Consecutivo"
                                        data-usuario="@item.Usuario">
                                    Editar
                                </button>                               
                            </td>
                            <td>
                                <!-- Eliminar -->
                                <form asp-action="EliminarRegistroVacio" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button class="btn btn-sm btn-danger">
                                        Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }

            </tbody>

        </table>

    </div>

</div>

<!-- ===================================================== -->
<!-- MODAL EXPORTAR EXCEL -->
<!-- ===================================================== -->
<div class="modal fade" id="modalExcel" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <form asp-action="ExportarHistorialExcel" method="post">

                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">
                        📗 Exportar Historial a Excel
                    </h5>

                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <div class="modal-body">

                    <div class="row g-3">

                        <!-- FECHA INICIO -->
                        <div class="col-md-6">
                            <label>Fecha Inicio</label>
                            <input type="date"
                                   name="fechaInicio"
                                   class="form-control"
                                   required />
                        </div>

                        <!-- FECHA FIN -->
                        <div class="col-md-6">
                            <label>Fecha Fin</label>
                            <input type="date"
                                   name="fechaFin"
                                   class="form-control"
                                   required />
                        </div>

                        <!-- HORA INICIO -->
                        <div class="col-md-6">
                            <label>Hora Inicio</label>
                            <input type="time"
                                   name="horaInicio"
                                   class="form-control" />
                        </div>

                        <!-- HORA FIN -->
                        <div class="col-md-6">
                            <label>Hora Fin</label>
                            <input type="time"
                                   name="horaFin"
                                   class="form-control" />
                        </div>

                    </div>

                    <hr />

                    <small class="text-muted">
                        Si no seleccionas horas, se exportará todo el rango de fechas.
                    </small>

                </div>

                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button class="btn btn-success">
                        📥 Descargar Excel
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

<!-- MODAL EDITAR HISTORIAL VACÍOS -->
<div class="modal fade" id="modalEditarVacio" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <form asp-action="EditarHistorial" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" id="editOrigen" name="origen" />

                <!-- HEADER -->
                <div class="modal-header bg-warning">
                    <h5 class="modal-title text-dark">
                        Editar reporte de vacío
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <!-- BODY -->
                <div class="modal-body">

                    <input type="hidden" id="editId" name="Id" />

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label">Fecha</label>
                            <input type="datetime-local"
                                   id="editFecha"
                                   name="Fecha"
                                   class="form-control"
                                   required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Consecutivo</label>
                            <input type="text"
                                   id="editConsecutivo"
                                   name="Consecutivo"
                                   class="form-control"
                                   required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Contenedor</label>
                            <input type="text"
                                   id="editContenedor"
                                   name="Contenedor"
                                   class="form-control"
                                   readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Cliente</label>
                            <input type="text"
                                   id="editCliente"
                                   name="Cliente"
                                   class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Transportista</label>
                            <input type="text"
                                   id="editTransportista"
                                   name="Transportista"
                                   class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Usuario</label>
                            <input type="text"
                                   id="editUsuario"
                                   name="Usuario"
                                   class="form-control" />
                        </div>

                    </div>

                </div>

                <!-- FOOTER -->
                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button type="submit"
                            class="btn btn-success">
                        Guardar cambios
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>


<script>
    document.addEventListener("DOMContentLoaded", function () {

        document.querySelectorAll(".btnEditarVacio").forEach(btn => {

            btn.addEventListener("click", function () {

                document.getElementById("editOrigen").value = "Historial";

                document.getElementById("editId").value = this.dataset.id;
                document.getElementById("editFecha").value = this.dataset.fecha;
                document.getElementById("editConsecutivo").value = this.dataset.consecutivo;
                document.getElementById("editContenedor").value = this.dataset.contenedor;
                document.getElementById("editCliente").value = this.dataset.cliente;
                document.getElementById("editTransportista").value = this.dataset.transportista;
                document.getElementById("editUsuario").value = this.dataset.usuario;

                var modal = new bootstrap.Modal(
                    document.getElementById("modalEditarVacio")
                );

                modal.show();
            });

        });

    });
</script>