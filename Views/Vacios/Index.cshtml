@using BitacoraAlfipac.Models.Entidades
@using BitacoraAlfipac.Models.ViewModels
@model List<InventarioItemVM>

@{
    ViewData["Title"] = "Contenedores Vacíos";
}

@if (TempData["Ok"] != null)
{
    <div class="alert alert-success">@TempData["Ok"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div >

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">

        <div>
            <h3 class="text-success mb-0">📦 Contenedores Vacíos</h3>
            <small class="text-muted">Gestión de inventario sin carga</small>
        </div>

        <a asp-controller="Vacios"
               asp-action="Historial"
               class="btn btn-dark">
            📚 Historial Reportes
        </a>

    </div>

    <!-- ================= FILTROS ================= -->
    <form method="get" class="card shadow-sm p-3 mb-3">

        <div class="row g-2">

            <div class="col-md-3">
                <input type="text" name="contenedor" class="form-control"
                       placeholder="Contenedor"
                       value="@Context.Request.Query["contenedor"]" />
            </div>

            <div class="col-md-3">
                <input type="text" name="cliente" class="form-control"
                       placeholder="Cliente"
                       value="@Context.Request.Query["cliente"]" />
            </div>

            <div class="col-md-3">
                <input type="text" name="transportista" class="form-control"
                       placeholder="Transportista"
                       value="@Context.Request.Query["transportista"]" />
            </div>

            <div class="col-md-2">
                <select name="patio" class="form-select">
                    <option value="">Todos los patios</option>
                    <option value="S/Pat">Sin asignar</option>
                    <option value="P1">Patio 1</option>
                    <option value="P2">Patio 2</option>
                    <option value="2000">Andén 2000</option>
                    <option value="AgroQui">Químicos</option>
                </select>
            </div>

            <div class="col-md-1 d-grid">
                <button class="btn btn-success">Buscar</button>
            </div>

        </div>

        <div class="mt-2">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                Limpiar filtros
            </a>
        </div>

    </form>

    <!-- ================= TABLA ================= -->
    <div class="card shadow-sm">

        <div class="card-header bg-light">
            <strong>Listado de contenedores</strong>
        </div>

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>Contenedor</th>
                        <th>Marchamos</th>
                        <th>Tamaño</th>
                        <th>Chasis</th>
                        <th>Transportista</th>
                        <th>Cliente</th>
                        <th class="text-center">Ubicación</th>
                        <th class="text-center">Acción</th>
                    </tr>
                </thead>

                <tbody>

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                No hay contenedores vacíos con los filtros aplicados
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var v in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@v.Contenedor</td>
                                <td>@v.Marchamos</td>
                                <td>@v.Tamano</td>
                                <td>@v.Chasis</td>
                                <td>@v.Transportista</td>
                                <td>@v.Cliente</td>

                                <td class="text-center">
                                    <span class="badge bg-secondary">@v.Patio</span>
                                </td>

                                <td class="text-center">
                                    <button class="btn btn-sm btn-primary btnReportarVacio"
                                            data-contenedor="@v.Contenedor"
                                            data-cliente="@v.Cliente"
                                            data-transportista="@v.Transportista">
                                        📄 Reporte
                                    </button>
                                </td>
                            </tr>
                        }
                    }

                </tbody>

            </table>

        </div>
    </div>

</div>

<!-- ================= MODAL REPORTE ================= -->
<div class="modal fade" id="modalReporteVacio" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <form asp-action="GenerarReporteVacioPDF"
                  method="post"
                  target="_blank"
                  id="formReporte">

                @Html.AntiForgeryToken()

                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Generar reporte de vacío</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input type="hidden" id="repContenedor" name="contenedor" />
                    <input type="hidden" id="repCliente" name="cliente" />
                    <input type="hidden" id="repTransportista" name="transportista" />

                    <div class="mb-3">
                        <label class="form-label">Consecutivo</label>
                        <input id="txtConsecutivo"
                               name="consecutivo"
                               class="form-control"
                               required />
                    </div>

                    <div class="form-check mb-3">
                        <input type="checkbox" id="chkMulti" class="form-check-input" />
                        <label class="form-check-label">
                            Agregar más contenedores
                        </label>
                    </div>

                    <div id="multiContainer"
                         class="border rounded p-2"
                         style="display:none; max-height:200px; overflow-y:auto;">

                        @foreach (var v in Model)
                        {
                            <div class="form-check">
                                <input type="checkbox"
                                       class="form-check-input multi-check"
                                       value="@v.Contenedor"
                                       data-contenedor="@v.Contenedor"
                                       data-cliente="@v.Cliente"
                                       data-transportista="@v.Transportista" />

                                <label class="form-check-label">
                                    <strong>@v.Contenedor</strong>
                                    <span class="text-muted">(@v.Transportista)</span>
                                    <span class="text-muted">(@v.Patio)</span>
                                </label>
                            </div>
                        }

                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn btn-success">
                        Generar PDF
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- ================= HISTORIAL ================= -->
<hr />

<h4 class="mt-4 text-primary">📊 Reportes emitidos hoy</h4>

<div class="table-responsive">

    <table class="table table-sm table-bordered align-middle">

        <thead class="table-light">
            <tr>
                <th>Hora</th>
                <th>Contenedor</th>
                <th>Cliente</th>
                <th>Transportista</th>
                <th>Consecutivo</th>
                <th>Usuario</th>
                <th>PDF</th>
                <th>Editar</th>
                <th>Eliminar</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var r in (List<Vacio>)ViewBag.HistorialHoy)
            {
                <tr>
                    <td>@r.Fecha.ToString("HH:mm")</td>
                    <td>@r.Contenedor</td>
                    <td>@r.Cliente</td>
                    <td>@r.Transportista</td>
                    <td>@r.Consecutivo</td>
                    <td>@r.Usuario</td>

                    <td>
                        <a asp-action="Reimprimir"
                               asp-route-id="@r.Id"
                               target="_blank"
                               class="btn btn-sm btn-outline-primary">
                            PDF
                        </a>
                    </td>

                    <td>
                        <button type="button"
                                class="btn btn-warning btn-sm btnEditarVacio"
                                data-id="@r.Id"
                                data-fecha="@r.Fecha.ToString("yyyy-MM-ddTHH:mm")"
                                data-contenedor="@r.Contenedor"
                                data-cliente="@r.Cliente"
                                data-transportista="@r.Transportista"
                                data-consecutivo="@r.Consecutivo"
                                data-usuario="@r.Usuario">
                            ✏️
                        </button>
                    </td>

                    <td>
                        <form asp-action="EliminarRegistroVacio" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@r.Id" />
                            <button class="btn btn-sm btn-danger">🗑</button>
                        </form>
                    </td>

                </tr>
            }
        </tbody>

    </table>

</div>

<!-- ================= MODAL EDITAR ================= -->
<div class="modal fade" id="modalEditarVacio" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <form asp-action="EditarHistorial" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" id="editOrigen" name="origen" />

                <div class="modal-header bg-warning">
                    <h5 class="modal-title">Editar reporte de vacío</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input type="hidden" id="editId" name="Id" />

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label>Fecha</label>
                            <input type="datetime-local" id="editFecha" name="Fecha" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label>Consecutivo</label>
                            <input type="text" id="editConsecutivo" name="Consecutivo" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label>Contenedor</label>
                            <input type="text" id="editContenedor" name="Contenedor" class="form-control" readonly />
                        </div>

                        <div class="col-md-6">
                            <label>Cliente</label>
                            <input type="text" id="editCliente" name="Cliente" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label>Transportista</label>
                            <input type="text" id="editTransportista" name="Transportista" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label>Usuario</label>
                            <input type="text" id="editUsuario" name="Usuario" class="form-control" />
                        </div>

                    </div>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-success">Guardar</button>
                </div>

            </form>

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        document.querySelectorAll(".btnEditarVacio").forEach(btn => {

            btn.addEventListener("click", function () {

                document.getElementById("editOrigen").value = "Index";

                document.getElementById("editId").value = this.dataset.id;
                document.getElementById("editFecha").value = this.dataset.fecha;
                document.getElementById("editConsecutivo").value = this.dataset.consecutivo;
                document.getElementById("editContenedor").value = this.dataset.contenedor;
                document.getElementById("editCliente").value = this.dataset.cliente;
                document.getElementById("editTransportista").value = this.dataset.transportista;
                document.getElementById("editUsuario").value = this.dataset.usuario;

                var modal = new bootstrap.Modal(
                    document.getElementById("modalEditarVacio")
                );

                modal.show();
            });

        });

    });
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const chkMulti = document.getElementById("chkMulti");
        const multiContainer = document.getElementById("multiContainer");

        let contenedorBase = "";
        let clienteBase = "";
        let transportistaBase = "";

        // 🔘 BOTÓN REPORTE
        document.querySelectorAll(".btnReportarVacio").forEach(btn => {
            btn.addEventListener("click", function () {

                contenedorBase = this.dataset.contenedor;
                clienteBase = this.dataset.cliente;
                transportistaBase = this.dataset.transportista;

                // set valores base
                document.getElementById("repContenedor").value = contenedorBase;
                document.getElementById("repCliente").value = clienteBase;
                document.getElementById("repTransportista").value = transportistaBase;

                // reset UI
                chkMulti.checked = false;
                multiContainer.style.display = "none";

                // 🔥 RESET + OCULTAR EL PRINCIPAL
                document.querySelectorAll(".multi-check").forEach(c => {

                    c.checked = false;

                    const cont = c.dataset.contenedor;

                    if (cont === contenedorBase) {
                        c.closest(".form-check").style.display = "none";
                    } else {
                        c.closest(".form-check").style.display = "block";
                    }
                });

                var modal = new bootstrap.Modal(document.getElementById("modalReporteVacio"));
                fetch('/Vacios/ObtenerSiguienteConsecutivo')
                .then(r => r.json())
                .then(data => {
                    document.getElementById("txtConsecutivo").value = data.consecutivo;
                });
                modal.show();
            });
        });

        // 🔥 ACTIVAR MULTI
        chkMulti.addEventListener("change", function () {
            multiContainer.style.display = this.checked ? "block" : "none";
        });

        // 📦 SUBMIT FORM
        document.querySelector("#modalReporteVacio form")
            .addEventListener("submit", function () {

                if (!chkMulti.checked) return;

                let seleccionados = new Set();
                seleccionados.add(contenedorBase);

                document.querySelectorAll(".multi-check:checked").forEach(c => {
                    seleccionados.add(c.value);
                });

                document.getElementById("repContenedor").value =
                    Array.from(seleccionados).join(" / ");
            });

    });
</script>

<script>
    document.getElementById("formReporte")
    .addEventListener("submit", function () {

        setTimeout(() => {
            window.location.reload();
        }, 1000);

    });
</script>