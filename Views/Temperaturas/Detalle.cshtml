@model BitacoraAlfipac.Models.Entidades.ContenedorRefrigerado

<h3 class="mb-3">
    Contenedor refrigerado
</h3>

<form asp-action="ActualizarEncabezado" method="post" class="card p-3 mb-4">
    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="row g-3">

        <div class="col-md-4">
            <label class="form-label">Contenedor</label>
            <input type="text"
                   name="Contenedor"
                   class="form-control"
                   value="@Model.Contenedor"
                   required />
        </div>

        <div class="col-md-4">
            <label class="form-label">Fecha / Hora Ingreso</label>
            <input type="datetime-local"
                   name="FechaHoraIngreso"
                   class="form-control"
                   value="@Model.FechaHoraIngreso?.ToString("yyyy-MM-ddTHH:mm")" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Fecha / Hora Conexión</label>
            <input type="datetime-local"
                   name="FechaHoraConexion"
                   class="form-control"
                   value="@Model.FechaHoraConexion?.ToString("yyyy-MM-ddTHH:mm")" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Set Point (°C)</label>
            <input type="number"
                   step="0.1"
                   name="SetPoint"
                   class="form-control"
                   value="@Model.SetPoint?.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)" />
        </div>

        @if (Model.SetPoint != null)
        {
            <small class="text-muted">
                SetPoint actual: <strong>@Model.SetPoint.Value.ToString("0.0") °C</strong>
            </small>
        }

        <div class="col-md-4">
            <label class="form-label">Fecha / Hora Despacho</label>
            <input type="datetime-local"
                   name="FechaHoraDespacho"
                   class="form-control"
                   value="@Model.FechaHoraDespacho?.ToString("yyyy-MM-ddTHH:mm")" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Fecha / Hora Desconexión</label>
            <input type="datetime-local"
                   name="FechaHoraDesconexion"
                   class="form-control"
                   value="@Model.FechaHoraDesconexion?.ToString("yyyy-MM-ddTHH:mm")" />
        </div>

    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            Guardar cambios
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Volver
        </a>
    </div>
</form>

<div class="d-flex gap-2 mb-3">
    <h2>Exportar temperaturas</h2>

    <a asp-action="ExportarPdf" asp-route-id="@Model.Id" class="btn btn-danger">
        PDF
    </a>
    <a asp-action="ExportarExcel" asp-route-id="@Model.Id" class="btn btn-success">
        Excel
    </a>
    <a asp-action="ExportarCsv" asp-route-id="@Model.Id" class="btn btn-secondary">
        CSV
    </a>
</div>

<div class="card p-3 mb-3">
    <h5>Nuevo registro de temperatura</h5>

    <form asp-action="AgregarRegistro" method="post">
        <input type="hidden" name="contenedorId" value="@Model.Id" />

        <div class="row g-2">
            <div class="col-md-3">
                <input name="fechaHora" type="datetime-local" class="form-control" required />
            </div>
            <div class="col-md-2">
                <input name="temperatura" class="form-control" placeholder="°C" type="number" step="0.1" required />
            </div>
            <div class="col-md-5">
                <input name="observacion" class="form-control" placeholder="Observación" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-success w-100">Agregar</button>
            </div>
        </div>
    </form>
</div>

<table class="table table-sm table-bordered">
    <thead class="table-light">
        <tr>
            <th>Fecha / Hora</th>
            <th>Temperatura</th>
            <th>Observación</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model.RegistrosTemperatura.OrderByDescending(r => r.FechaHora))
        {
            <tr>
                <td>@r.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@r.Temperatura.ToString("0.0") °C</td>
                <td>@r.Observacion</td>
                <td class="text-center">
                    <form asp-action="EliminarRegistro" method="post">
                        <input type="hidden" name="id" value="@r.Id" />
                        <input type="hidden" name="contenedorId" value="@Model.Id" />
                        <button class="btn btn-danger btn-sm"
                                onclick="return confirm('¿Eliminar este registro de temperatura?')">
                            ✖
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
