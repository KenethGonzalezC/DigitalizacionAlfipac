<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Alfipac - SCL</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BitacoraAlfipac.styles.css" asp-append-version="true" />

    <!-- ICONOS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<body>

    <div class="app-wrapper">

        <!-- SIDEBAR -->
        <aside class="sidebar">

            <!-- HEADER -->
            <div class="sidebar-header">
                <img src="~/images/logo.jpg" />
                <span>SCL</span>
            </div>

            <!-- MENÚ -->
            <nav class="sidebar-menu">

                @if (!User.IsInRole("Usuario"))
                {
                    <a asp-controller="Home" asp-action="Index" class="menu-item">
                        <i class="bi bi-house-door"></i>
                        <span>Inicio</span>
                    </a>
                 }

                @if (User.IsInRole("Usuario"))
                {
                    <a asp-controller="Usuario" asp-action="Index" class="menu-item">
                        <i class="bi bi-house-door"></i>
                        <span>Inicio (Solo Lectura)</span>
                    </a>
                }

                @if (User.IsInRole("Usuario"))
                {
                    <a asp-controller="Bitacora" asp-action="Index" class="menu-item">
                        <i class="bi bi-journal-text"></i>
                        <span>Bitacora</span>
                    </a>
                }

                @if (User.IsInRole("Usuario"))
                {
                    <a asp-controller="Inventario" asp-action="InventarioLectura" class="menu-item">
                        <i class="bi bi-box-seam"></i>
                        <span>Inventario</span>
                    </a>
                }

                @if (User.IsInRole("Usuario"))
                {
                    <a asp-controller="Usuario" asp-action="Refrigerados" class="menu-item">
                        <i class="bi bi-thermometer-half"></i>
                        <span>Refrigerados</span>
                    </a>
                }

                @if (User.IsInRole("Administrador") || User.IsInRole("Digitador") || User.IsInRole("Patio"))
                {
                    <a asp-controller="Inventario" asp-action="Index" class="menu-item">
                        <i class="bi bi-box-seam"></i>
                        <span>Inventario</span>
                    </a>
                }

                @if (User.IsInRole("Administrador") || User.IsInRole("Digitador"))
                {
                    <a asp-controller="BitacoraIngresos" asp-action="Index" class="menu-item">
                        <i class="bi bi-arrow-down-circle"></i>
                        <span>Ingresos</span>
                    </a>

                    <a asp-controller="BitacoraDespachos" asp-action="Index" class="menu-item">
                        <i class="bi bi-arrow-up-circle"></i>
                        <span>Despachos</span>
                    </a>
                }

                @if (User.IsInRole("Administrador") || User.IsInRole("Digitador") || User.IsInRole("Patio"))
                {
                    <a asp-controller="Temperaturas" asp-action="Index" class="menu-item">
                        <i class="bi bi-thermometer-half"></i>
                        <span>Refrigerados</span>
                    </a>
                }

                <a asp-controller="HistorialContenedores" asp-action="Index" class="menu-item">
                    <i class="bi bi-clock-history"></i>
                    <span>Historial</span>
                </a>

                @if (User.IsInRole("Administrador") || User.IsInRole("Digitador"))
                {
                    <a asp-controller="Bitacora" asp-action="Index" class="menu-item">
                        <i class="bi bi-journal-text"></i>
                        <span>Bitácora</span>
                    </a>

                    <a asp-controller="Datos" asp-action="Index" class="menu-item">
                        <i class="bi bi-database"></i>
                        <span>Datos</span>
                    </a>

                    <a asp-controller="ActasPermanencias" asp-action="Index" class="menu-item">
                        <i class="bi bi-file-earmark-text"></i>
                        <span>Actas y PAB</span>
                    </a>
                }

                @if (User.IsInRole("Administrador"))
                {
                    <a asp-controller="Usuarios" asp-action="Index" class="menu-item text-danger">
                        <i class="bi bi-people"></i>
                        <span>Usuarios</span>
                    </a>
                }              
                
            </nav>

        </aside>

        <!-- MAIN -->
        <div class="main-content">

            <!-- TOPBAR -->
            <header class="topbar">

                <div class="d-flex align-items-center gap-3">

                    <button id="toggleSidebar" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-list"></i>
                    </button>

                    <strong>@ViewData["Title"]</strong>

                </div>

                <div class="user-section d-flex align-items-center gap-3">

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <span class="text-muted small">
                            <i class="bi bi-person-circle"></i>
                            @User.Identity.Name
                        </span>

                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit" class="btn btn-sm btn-danger">
                                <i class="bi bi-box-arrow-right"></i>
                            </button>
                        </form>
                    }

                </div>

            </header>

            <!-- CONTENT -->
            <main class="content">
                @RenderBody()
            </main>

            <!-- FOOTER -->
            <footer class="footer text-muted">
                <div class="px-4 py-2">
                    &copy; 2026 - Sistema de Control Logístico · Alfipac
                </div>
            </footer>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- SIDEBAR TOGGLE + ESTADO -->
    <script>
            const toggleBtn = document.getElementById("toggleSidebar");

            if (localStorage.getItem("sidebar") === "collapsed") {
                document.body.classList.add("sidebar-collapsed");
            }

            toggleBtn.addEventListener("click", () => {
                document.body.classList.toggle("sidebar-collapsed");

                const isCollapsed = document.body.classList.contains("sidebar-collapsed");
                localStorage.setItem("sidebar", isCollapsed ? "collapsed" : "expanded");
            });
    </script>

    <!-- ITEM ACTIVO -->
    <script>
            const links = document.querySelectorAll(".sidebar-menu a");
            const currentUrl = window.location.pathname.toLowerCase();

            links.forEach(link => {
                if (currentUrl.includes(link.getAttribute("href").toLowerCase())) {
                    link.classList.add("active");
                }
            });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>