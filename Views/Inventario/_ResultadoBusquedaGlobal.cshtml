@using BitacoraAlfipac.Models.ViewModels
@model BusquedaGlobalContenedorVM

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm">
        @TempData["Success"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm">
        @TempData["Error"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}

<div class="container mt-3">

    @if (Model == null)
    {
        <div class="alert alert-warning shadow-sm">
            ⚠️ Contenedor no encontrado
        </div>
    }
    else
    {
        <!-- HEADER -->
        <div class="mb-3">

            <h4 class="mb-0">
                ✏️ Edición de contenedor
            </h4>

            <small class="text-muted">
                Actualización rápida desde búsqueda global
            </small>

        </div>

        <!-- CARD PRINCIPAL -->
        <div class="card shadow-sm border-0">

            <div class="card-body">

                <form asp-controller="Inventario"
                      asp-action="ConfirmarEdicionSinAsignar"
                      method="post">

                    @Html.AntiForgeryToken()

                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="ubicacionActual" value="@Model.UbicacionActual" />

                    <!-- INFO -->
                    <div class="row mb-3">

                        <div class="col-md-6">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted">Contenedor</small>
                                <div class="fw-semibold fs-5">
                                    @Model.Contenedor
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted">Ubicación actual</small>
                                <div class="fw-semibold">
                                    @Model.UbicacionActual
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="p-2 border rounded bg-light">
                                <small class="text-muted">Tamaño</small>
                                <div class="fw-semibold">
                                    @Model.Tamano
                                </div>
                            </div>
                        </div>

                        <!--VACIOS-->
                        @if (Model.EstadoCarga.Equals("VACIO",
                        StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="col-md-6">
                                <div class="p-2 border rounded bg-light">

                                    <small class="text-muted">
                                        Estado Vacíos
                                    </small>

                                    @if (Model.YaReportado)
                                    {
                                        <div class="fw-semibold text-success">
                                            ✓ Reportado
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="fw-semibold text-danger">
                                            ❌ No reportado
                                        </div>
                                    }

                                </div>
                            </div>
                        }

                    </div>

                    <!-- DATOS OPERATIVOS -->
                    <div class="row g-3 mb-3">

                        <div class="col-md-4">
                            <label class="form-label">Chasis</label>
                            <input name="Chasis"
                                   value="@Model.Chasis"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Transportista</label>
                            <input name="Transportista"
                                   value="@Model.Transportista"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Cliente</label>
                            <input name="Cliente"
                                   value="@Model.Cliente"
                                   class="form-control" />
                        </div>

                    </div>

                    <div class="row g-3 mb-4">

                        <div class="col-md-4">
                            <label class="form-label">Marchamos</label>
                            <input name="Marchamos"
                                   value="@Model.Marchamos"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Estado</label>
                            <select name="EstadoCarga" class="form-select">

                                <option value="Vacio" selected="@(Model.EstadoCarga == "Vacio")">
                                    Vacío
                                </option>

                                <option value="Cargado" selected="@(Model.EstadoCarga == "Cargado")">
                                    Cargado
                                </option>

                            </select>
                        </div>

                        <!-- ACCIÓN CRÍTICA -->
                        <div class="col-md-4">

                            <label class="form-label text-primary">
                                📍 Mover ubicación
                            </label>

                            <select name="Ubicacion" class="form-select border-primary">

                                <option value="">No mover</option>
                                <option value="SinAsignar">Sin asignar</option>
                                <option value="Patio1">Patio 1</option>
                                <option value="Patio2">Patio 2</option>
                                <option value="Anden2000">Andén 2000</option>
                                <option value="PatioQuimicos">Químicos</option>

                            </select>

                        </div>

                    </div>

                    <!-- BOTÓN -->
                    <button class="btn btn-success w-100 py-2">
                        ✔ Confirmar cambios
                    </button>                    

                </form>

                @if (User.IsInRole("Administrador"))
                {
                    <hr />

                    <form asp-controller="Inventario"
                          asp-action="EliminarContenedorInventario"
                          method="post">

                        @Html.AntiForgeryToken()

                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="ubicacionActual" value="@Model.UbicacionActual" />
                        <input type="hidden"
                               name="motivo"
                               value="Eliminación manual desde búsqueda global" />

                        <button type="submit"
                                id="btnEliminarContenedor"
                                class="btn btn-danger w-100">
                            🗑 Eliminar
                        </button>

                    </form>
                }

            </div>

        </div>
    }

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const btnEliminar =
            document.getElementById("btnEliminarContenedor");

        btnEliminar?.addEventListener("click", function (e) {

            const confirmado = confirm(
                "⚠️ ATENCIÓN\n\n" +
                "Esta acción eliminará el contenedor SOLO del inventario físico.\n\n" +
                "NO se eliminarán ingresos, despachos ni historial.\n\n" +
                "¿Desea continuar?"
            );

            if (!confirmado) {
                e.preventDefault();
                e.stopPropagation();
            }

        });

    });
</script>