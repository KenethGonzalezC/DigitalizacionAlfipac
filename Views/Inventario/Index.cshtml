@using BitacoraAlfipac.Models.ViewModels
@model InventarioIndexVM

<div class="container mt-4">

    <!-- HEADER -->
    <div class="mb-3">
        <h3 class="mb-0">📦 Inventario de Contenedores</h3>
        <small class="text-muted">Gestión operativa de patios y movimientos</small>
    </div>

    <!-- ACCIONES PRINCIPALES -->
    <div class="d-flex flex-wrap gap-2 mb-3">

        <a asp-controller="Inventario"
               asp-action="InventarioGeneral"
               class="btn btn-dark">
            📊 Inventario General
        </a>

        <a asp-controller="BitacoraIngresos"
               asp-action="Vehiculos"
               class="btn btn-outline-primary">
            🚗 Vehículos
        </a>

        <button class="btn btn-outline-dark"
                data-bs-toggle="modal"
                data-bs-target="#modalExportarGeneral">
            🌎 Exportar
        </button>        

    </div>

    <!-- PATIOS -->
    <div class="card shadow-sm mb-4">

        <div class="card-header bg-white">
            <strong>📍 Accesos por patio</strong>
        </div>

        <div class="card-body">

            <div class="row g-3">

                <div class="col-md-3">
                    <a asp-controller="Patio1" asp-action="Index"
                           class="btn btn-outline-primary w-100">
                        🟦 Patio 1
                    </a>
                </div>

                <div class="col-md-3">
                    <a asp-controller="Patio2" asp-action="Index"
                           class="btn btn-outline-success w-100">
                        🟩 Patio 2
                    </a>
                </div>

                <div class="col-md-3">
                    <a asp-controller="Anden2000" asp-action="Index"
                           class="btn btn-outline-warning w-100">
                        🟨 Andén 2000
                    </a>
                </div>

                <div class="col-md-3">
                    <a asp-controller="PatioQuimicos" asp-action="Index"
                           class="btn btn-outline-danger w-100">
                        ☣️ Químicos
                    </a>
                </div>

            </div>

        </div>

    </div>

    <!-- BUSQUEDA GLOBAL -->
    <div class="card shadow-sm mb-4">

        <div class="card-body">

            <form id="formBusquedaGlobal">

                <div class="row g-2 align-items-end">

                    <div class="col-md-6">
                        <label class="form-label">Búsqueda global</label>
                        <input name="contenedor"
                               class="form-control"
                               placeholder="Buscar contenedor..." />
                    </div>

                    <div class="col-md-3 d-grid">
                        <button type="submit" class="btn btn-primary">
                            🔎 Buscar
                        </button>
                    </div>

                    <div class="col-md-3 d-grid">
                        <a asp-action="Index"
                               class="btn btn-outline-secondary">
                            Limpiar
                        </a>
                    </div>

                </div>

            </form>

        </div>

    </div>

    <!-- DRAG & DROP -->
    <div class="card shadow-sm mb-4">

        <div class="card-header bg-dark text-white">
            🚚 Traslado rápido de contenedores
            <small class="d-block text-white-50">
                Arrastre ☰ hacia el patio destino
            </small>
        </div>

        <div class="card-body">

            <div class="row g-3">

                <div class="col-md-3">
                    <div class="drop-box border rounded p-3 text-center bg-light"
                         data-destino="Patio1">
                        📦 Patio 1
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="drop-box border rounded p-3 text-center bg-light"
                         data-destino="Patio2">
                        📦 Patio 2
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="drop-box border rounded p-3 text-center bg-light"
                         data-destino="Anden2000">
                        🏗️ Andén 2000
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="drop-box border rounded p-3 text-center bg-light"
                         data-destino="PatioQuimicos">
                        ☣️ Químicos
                    </div>
                </div>

            </div>

        </div>

    </div>

    <button id="btnGuardarOrden" class="btn btn-success">
        💾 Guardar orden
    </button>

    <div>
        <h5></h5>
    </div>

    <!-- TABLA -->
    <div class="card shadow-sm">

        <div class="card-header bg-white">
            <strong>📋 Contenedores sin asignar patio</strong>
        </div>

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover table-striped table-sm align-middle mb-0">

                    <thead class="table-light">
                        <tr>
                            <th style="width:50px;">Mover</th>
                            <th>Contenedor</th>
                            <th>Marchamos</th>
                            <th>Tamaño</th>
                            <th>Chasis</th>
                            <th>Transportista</th>
                            <th>Cliente</th>
                            <th>Estado</th>
                            <th>✔</th>
                            <th>Ubicación</th>
                            <th>Mover</th>
                        </tr>
                    </thead>

                    <tbody id="tablaOrden">
                        @foreach (var c in Model.ContenedoresSinAsignar)
                        {
                            <tr data-id="@c.Id">

                                <form method="post">

                                    <input type="hidden" name="id" value="@c.Id" />

                                    <td class="text-center">
                                        <span class="handle fs-5" style="cursor:grab;">☰</span>
                                    </td>

                                    <td class="contenedor-nombre fw-semibold">
                                        @c.Contenedor
                                    </td>

                                    <td>
                                        <input name="marchamos"
                                               value="@c.Marchamos"
                                               class="form-control form-control-sm" />
                                    </td>

                                    <td>@c.Tamano</td>

                                    <td>
                                        <input name="chasis"
                                               value="@c.Chasis"
                                               class="form-control form-control-sm" />
                                    </td>

                                    <td>
                                        <input name="transportista"
                                               value="@c.Transportista"
                                               class="form-control form-control-sm" />
                                    </td>

                                    <td>
                                        <input name="cliente"
                                               value="@c.Cliente"
                                               class="form-control form-control-sm" />
                                    </td>

                                    <td>
                                        <select name="estadoCarga"
                                                class="form-select form-select-sm">
                                            <option value="Vacio" selected="@(c.EstadoCarga == "Vacio")">Vacío</option>
                                            <option value="Cargado" selected="@(c.EstadoCarga == "Cargado")">Cargado</option>
                                        </select>
                                    </td>

                                    <td class="text-center">
                                        <button formaction="@Url.Action("ConfirmarEdicion", "Inventario")"
                                                class="btn btn-sm btn-primary">
                                            ✔
                                        </button>
                                    </td>

                                    <td>
                                        <select name="ubicacion"
                                                class="form-select form-select-sm">
                                            <option value="">No mover</option>
                                            <option value="Patio1">Patio 1</option>
                                            <option value="Patio2">Patio 2</option>
                                            <option value="Anden2000">Andén 2000</option>
                                            <option value="PatioQuimicos">Patio Químicos</option>
                                        </select>
                                    </td>

                                    <td>
                                        <button formaction="@Url.Action("Mover", "Inventario")"
                                                class="btn btn-sm btn-success">
                                            Mover
                                        </button>
                                    </td>

                                </form>

                            </tr>
                        }
                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<!-- MODAL BUSQUEDA -->
<div class="modal fade" id="modalBusquedaGlobal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Resultado de búsqueda</h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body" id="contenidoModalBusqueda"></div>

        </div>
    </div>
</div>

<div class="modal fade" id="modalExportarGeneral" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title">Reporte General de Contenedores</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input name="nombre" class="form-control mb-2" placeholder="Responsable" required />
                    <input type="date" name="fecha" class="form-control mb-2" required />
                    <input name="turno" class="form-control" placeholder="Turno" />
                </div>

                <div class="modal-footer d-flex gap-2">
                    <button formaction="/Inventario/ExportarGeneralPDF" class="btn btn-danger flex-fill">PDF</button>
                    <button formaction="/Inventario/ExportarGeneralExcel" class="btn btn-success flex-fill">Excel</button>
                    <button formaction="/Inventario/ExportarGeneralCSV" class="btn btn-primary flex-fill">CSV</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

        let filaSeleccionada = null;

        // =========================
        // ORDENAR TABLA
        // =========================
        new Sortable(document.getElementById("tablaOrden"), {
        animation: 150,
        handle: ".handle",
        ghostClass: "table-warning",

        onStart: function (evt) {
        filaSeleccionada = evt.item;
        },

        onEnd: function () {
        setTimeout(() => {
        filaSeleccionada = null;
        }, 150);
        }
        });


        // =========================
        // BOXES DESTINO
        // =========================
        document.querySelectorAll(".drop-box").forEach(box => {

        box.addEventListener("dragover", function (e) {
        e.preventDefault();
        this.classList.add("bg-success", "text-white");
        });

        box.addEventListener("dragleave", function () {
        this.classList.remove("bg-success", "text-white");
        });

        box.addEventListener("drop", function (e) {

        e.preventDefault();

        this.classList.remove("bg-success", "text-white");

        if (!filaSeleccionada) return;

        const destino = this.dataset.destino;
        const id = filaSeleccionada.dataset.id;

        const nombre =
        filaSeleccionada.querySelector(".contenedor-nombre").innerText;

        const marchamos =
        filaSeleccionada.querySelector("input[name='marchamos']").value;

        const estado =
        filaSeleccionada.querySelector("select[name='estadoCarga']").value;

        if (!confirm(`¿Mover contenedor ${nombre} a ${destino}?`)) {
        filaSeleccionada = null;
        return;
        }

        const data = new URLSearchParams();
        data.append("id", id);
        data.append("marchamos", marchamos);
        data.append("estadoCarga", estado);
        data.append("ubicacion", destino);

        fetch('/Inventario/Mover', {
        method: 'POST',
        headers: {
        'Content-Type': 'application/x-www-form-urlencoded'
        },
        body: data.toString()
        })
        .then(r => {
        if (r.ok) {
        location.reload();
        } else {
        alert("No se pudo mover.");
        }
        });

        });

        });


        // =========================
        // GUARDAR ORDEN
        // =========================
        document.getElementById("btnGuardarOrden")
        .addEventListener("click", function () {

        let lista = [];

        document.querySelectorAll("#tablaOrden tr")
        .forEach((fila, index) => {

        lista.push({
        id: parseInt(fila.dataset.id),
        orden: index + 1,

        marchamos: fila.querySelector("input[name='marchamos']").value,
        estadoCarga: fila.querySelector("select[name='estadoCarga']").value,
        chasis: fila.querySelector("input[name='chasis']").value,
        transportista: fila.querySelector("input[name='transportista']").value,
        cliente: fila.querySelector("input[name='cliente']").value
        });

        });

        fetch('/Inventario/GuardarOrden', {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json'
        },
        body: JSON.stringify(lista)
        })
        .then(r => r.json())
        .then(res => {

        if (res.success) {
        alert("Orden guardado correctamente");
        location.reload();
        }

        });

        });


        // =========================
        // BUSQUEDA GLOBAL
        // =========================
        document.getElementById("formBusquedaGlobal")
        .addEventListener("submit", function (e) {

        e.preventDefault();

        const contenedor =
        this.querySelector("input[name='contenedor']").value;

        fetch(`/Inventario/BuscarGlobal?contenedor=${contenedor}`)
        .then(r => r.text())
        .then(html => {

        document.getElementById("contenidoModalBusqueda").innerHTML = html;

        new bootstrap.Modal(
        document.getElementById("modalBusquedaGlobal")
        ).show();

        });

        });


        // =========================
        // FORMULARIOS MODAL
        // =========================
        document.addEventListener("submit", function (e) {

        const form = e.target.closest("#modalBusquedaGlobal form");

        if (!form) return;

        e.preventDefault();

        fetch(form.action, {
        method: "POST",
        body: new FormData(form)
        })
        .then(r => r.json())
        .then(res => {

        if (res.success) {

        bootstrap.Modal.getInstance(
        document.getElementById("modalBusquedaGlobal")
        ).hide();

        location.reload();
        }

        });

        });

        });
    </script>
}
