@model List<BitacoraAlfipac.Models.Entidades.ContenedorBackupDespacho>

<div class="container-fluid">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Backups de despachos</h2>
            <small class="text-muted">Zona de seguridad de registros eliminados</small>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-secondary">
                ← Volver
            </a>

            <button class="btn btn-danger"
                    data-bs-toggle="modal"
                    data-bs-target="#deleteOldBackupsModal">
                🧹 Limpiar +7 días
            </button>
        </div>
    </div>

    <!-- FILTRO -->
    <div class="card shadow-sm mb-3">
        <div class="card-body">

            <form method="get" class="row g-3 align-items-end">

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Filtrar por fecha</label>
                    <input type="date"
                           name="fecha"
                           class="form-control"
                           value="@ViewBag.FechaSeleccionada" />
                </div>

                <div class="col-md-auto">
                    <button type="submit" class="btn btn-primary">
                        Filtrar
                    </button>
                    <a asp-action="Backups" class="btn btn-outline-secondary">
                        Limpiar
                    </a>
                </div>

                <div class="col-md-auto ms-auto text-muted">
                    Mostrando <strong>@Model.Count</strong> de <strong>@ViewBag.TotalRegistros</strong> registros
                </div>

            </form>

        </div>
    </div>

    <!-- TABLA -->
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>Contenedor</th>
                        <th>Marchamos</th>
                        <th>Transportista</th>
                        <th>Cliente</th>
                        <th>Chasis</th>
                        <th>Patio origen</th>
                        <th>Fecha backup</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-5">
                                No se encontraron registros
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var b in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@b.Contenedor</td>
                                <td>@b.Marchamos</td>
                                <td>@b.Transportista</td>
                                <td>@b.Cliente</td>
                                <td>@b.Chasis</td>
                                <td>@b.PatioOrigen</td>
                                <td>@b.FechaRespaldo.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    }
                </tbody>

            </table>
        </div>
    </div>

    <!-- PAGINACIÓN -->
    @if (ViewBag.TotalPaginas > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">

                <li class="page-item @(ViewBag.PaginaActual == 1 ? "disabled" : "")">
                    <a class="page-link"
                           asp-action="Backups"
                           asp-route-page="@(ViewBag.PaginaActual - 1)"
                           asp-route-fecha="@ViewBag.FechaSeleccionada">
                        Anterior
                    </a>
                </li>

                @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
                {
                    <li class="page-item @(i == ViewBag.PaginaActual ? "active" : "")">
                        <a class="page-link"
                               asp-action="Backups"
                               asp-route-page="@i"
                               asp-route-fecha="@ViewBag.FechaSeleccionada">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(ViewBag.PaginaActual == ViewBag.TotalPaginas ? "disabled" : "")">
                    <a class="page-link"
                           asp-action="Backups"
                           asp-route-page="@(ViewBag.PaginaActual + 1)"
                           asp-route-fecha="@ViewBag.FechaSeleccionada">
                        Siguiente
                    </a>
                </li>

            </ul>
        </nav>
    }

</div>

<div class="modal fade" id="deleteOldBackupsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <form asp-action="EliminarBackupsAntiguos" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Eliminar backups antiguos</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <p class="fw-semibold text-danger">
                        ⚠️ Esta acción eliminará todos los backups con más de 7 días de antigüedad.
                    </p>

                    <p class="text-muted mb-0">
                        Esta operación no se puede deshacer.
                    </p>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button class="btn btn-danger">
                        Eliminar definitivamente
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>