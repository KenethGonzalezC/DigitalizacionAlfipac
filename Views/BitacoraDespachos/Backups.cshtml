@model List<BitacoraAlfipac.Models.Entidades.ContenedorBackupDespacho>

<h3 class="mb-3">Backups de Despachos (Zona de Seguridad)</h3>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <label class="form-label">Filtrar por fecha</label>
        <input type="date" name="fecha" class="form-control" value="@ViewBag.FechaSeleccionada" />
    </div>
    <div class="col-auto align-self-end">
        <button type="submit" class="btn btn-primary">Filtrar</button>
        <a asp-action="Backups" class="btn btn-outline-secondary">Limpiar</a>
    </div>
</form>

<p class="text-muted">
    Mostrando <strong>@Model.Count</strong> de <strong>@ViewBag.TotalRegistros</strong> registros
</p>

<div class="table-responsive">
    <table class="table table-bordered table-sm table-striped shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Contenedor</th>
                <th>Marchamos</th>
                <th>Transportista</th>
                <th>Cliente</th>
                <th>Chasis</th>
                <th>Patio Origen</th>
                <th>Fecha Backup</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">
                        No se encontraron registros
                    </td>
                </tr>
            }
            else
            {
                foreach (var b in Model)
                {
                    <tr>
                        <td>@b.Contenedor</td>
                        <td>@b.Marchamos</td>
                        <td>@b.Transportista</td>
                        <td>@b.Cliente</td>
                        <td>@b.Chasis</td>
                        <td>@b.PatioOrigen</td>
                        <td>@b.FechaRespaldo.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- PAGINACIÓN -->
@if (ViewBag.TotalPaginas > 1)
{
    <nav class="mt-3">
        <ul class="pagination">
            <li class="page-item @(ViewBag.PaginaActual == 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Backups"
                   asp-route-page="@(ViewBag.PaginaActual - 1)"
                   asp-route-fecha="@ViewBag.FechaSeleccionada">
                    Anterior
                </a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
            {
                <li class="page-item @(i == ViewBag.PaginaActual ? "active" : "")">
                    <a class="page-link"
                       asp-action="Backups"
                       asp-route-page="@i"
                       asp-route-fecha="@ViewBag.FechaSeleccionada">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(ViewBag.PaginaActual == ViewBag.TotalPaginas ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Backups"
                   asp-route-page="@(ViewBag.PaginaActual + 1)"
                   asp-route-fecha="@ViewBag.FechaSeleccionada">
                    Siguiente
                </a>
            </li>
        </ul>
    </nav>
}
