@model BitacoraAlfipac.Models.ViewModels.BitacoraIngresosViewModel

@{
    ViewData["Title"] = $"Ingresos del día - {Model.FechaSeleccionada:dd/MM/yyyy}";
}

@if (TempData["Ok"] != null)
{
    <div class="alert alert-success">@TempData["Ok"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="container-fluid">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Registro de ingresos</h2>
            <small class="text-muted">Ingreso de contenedores al almacén</small>
        </div>
    </div>

    <!-- =========================
         FORMULARIO
    ========================= -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">

            <h5 class="fw-bold mb-3">Registrar ingreso</h5>

            <form method="post">
                @Html.AntiForgeryToken()

                <div class="row g-3">

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Contenedor</label>
                        <div class="input-group">
                            <input asp-for="Contenedor" id="inputContenedor" class="form-control" required />
                            <button type="button" id="btnBuscarActa" class="btn btn-outline-secondary">
                                Buscar
                            </button>
                        </div>
                        <small id="resultadoBusqueda" class="text-muted fw-semibold"></small>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Fecha y hora</label>
                        <input asp-for="FechaHoraIngreso"
                               type="datetime-local"
                               step="60"
                               class="form-control"
                               value="@Model.FechaHoraIngreso.ToString("yyyy-MM-ddTHH:mm")"
                               required />
                    </div>                    

                    <div class="col-md-3">
                        <label class="form-label">Marchamos</label>
                        <input asp-for="Marchamos" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Transportista</label>
                        <input asp-for="Transportista" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Cliente</label>
                        <input asp-for="Cliente" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Tamaño</label>
                        <input asp-for="Tamano" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Chofer</label>
                        <input asp-for="Chofer" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Placa cabezal</label>
                        <input asp-for="PlacaCabezal" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Chasis</label>
                        <input asp-for="Chasis" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Viaje / DUA</label>
                        <input asp-for="ViajeDua" class="form-control" />
                    </div>

                </div>                

                <div class="mt-4 text-end">

                    <div class="col-md-4 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="EsRefrigerado" class="form-check-input" type="checkbox" />
                            <label asp-for="EsRefrigerado" class="form-check-label fw-semibold">
                                Refrigerado
                            </label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary px-4">
                        Registrar ingreso
                    </button>
                </div>

            </form>
        </div>
    </div>

    <!-- =========================
         HEADER TABLA
    ========================= -->
    <div class="card mb-3">
        <div class="card-body d-flex flex-wrap align-items-center gap-3">

            <h5 class="fw-bold mb-0">
                Ingresos del día – @Model.FechaSeleccionada.ToString("dd/MM/yyyy")
            </h5>

            <form method="get" class="d-flex align-items-center gap-2 ms-auto">
                <input type="date"
                       name="fecha"
                       class="form-control"
                       value="@Model.FechaSeleccionada.ToString("yyyy-MM-dd")" />

                <button type="submit" class="btn btn-outline-primary">
                    Filtrar
                </button>
            </form>

            <div>
                <a asp-action="Index"
                       class="btn btn-secondary flex-fill">
                    Hoy
                </a>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-danger"
                        data-bs-toggle="modal"
                        data-bs-target="#modalExportarIngresosPdf">
                    📄 PDF
                </button>

                <a asp-action="ExportarExcel"
                   asp-route-fecha="@Model.FechaSeleccionada.ToString("yyyy-MM-dd")"
                   class="btn btn-success btn-sm">Excel</a>

                <a asp-action="ExportarCsv"
                   asp-route-fecha="@Model.FechaSeleccionada.ToString("yyyy-MM-dd")"
                   class="btn btn-outline-secondary btn-sm">CSV</a>
            </div>

        </div>
    </div>

    <!-- =========================
         TABLA
    ========================= -->
    <div class="card">
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Hora</th>
                        <th>Contenedor</th>
                        <th>Marchamos</th>
                        <th>Transportista</th>
                        <th>Cliente</th>
                        <th>Tamaño</th>
                        <th>Chasis</th>
                        <th>Viaje / DUA</th>
                        <th></th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Ingresos.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-4">
                                No existen ingresos para esta fecha
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.Ingresos)
                        {
                            <tr>
                                <td>@item.FechaHoraIngreso.ToString("HH:mm")</td>
                                <td class="fw-semibold">@item.Contenedor</td>
                                <td>@item.Marchamos</td>
                                <td>@item.Transportista</td>
                                <td>@item.Cliente</td>
                                <td>@item.Tamaño</td>
                                <td>@item.Chasis</td>
                                <td>@item.ViajeDua</td>

                                <td>
                                    <button class="btn btn-sm btn-danger"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal"
                                            data-id="@item.Id"
                                            data-contenedor="@item.Contenedor"
                                            data-marchamos="@item.Marchamos"
                                            data-fecha="@item.FechaHoraIngreso.ToString("yyyy-MM-dd HH:mm")"
                                            data-transportista="@item.Transportista"
                                            data-cliente="@item.Cliente"
                                            data-tamano="@item.Tamaño"
                                            data-chasis="@item.Chasis"
                                            data-viaje="@item.ViajeDua">
                                        Eliminar
                                    </button>
                                </td>

                                <td>
                                    @if (User.IsInRole("Administrador"))
                                    {
                                        <button class="btn btn-sm btn-outline-secondary"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editarModal"
                                                onclick="cargarEditar(@item.Id)">
                                            Editar
                                        </button>
                                    }
                                </td>

                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

<!-- =========================
     MODAL ELIMINAR
========================= -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirmar eliminación</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input type="hidden" name="id" id="deleteId" />
                    <input type="hidden" name="fecha" value="@Model.FechaSeleccionada.ToString("yyyy-MM-dd")" />

                    <p class="text-danger fw-semibold">
                        ⚠️ Esta acción eliminará completamente el ingreso.
                    </p>

                    <div class="row g-3">
                        <input class="form-control" id="deleteContenedor" readonly />
                        <input class="form-control" id="deleteMarchamos" readonly />
                        <input class="form-control" id="deleteFecha" readonly />
                        <input class="form-control" id="deleteTransportista" readonly />
                        <input class="form-control" id="deleteCliente" readonly />
                        <input class="form-control" id="deleteTamano" readonly />
                        <input class="form-control" id="deleteChasis" readonly />
                        <input class="form-control" id="deleteViaje" readonly />
                    </div>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-danger">Eliminar</button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- =========================
     MODAL EDITAR
========================= -->
<div class="modal fade" id="editarModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <form method="post" asp-action="Editar">
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title">Editar ingreso</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input type="hidden" name="Id" id="editId" />

                    <div class="row g-3">

                        <input id="editContenedor" class="form-control" readonly />
                        <input id="editMarchamos" name="Marchamos" class="form-control" />
                        <input id="editFechaHora" name="FechaHoraIngreso" type="datetime-local" class="form-control" />
                        <input id="editTransportista" name="Transportista" class="form-control" />
                        <input id="editCliente" name="Cliente" class="form-control" />
                        <input id="editTamano" name="Tamano" class="form-control" />
                        <input id="editChofer" name="Chofer" class="form-control" />
                        <input id="editPlacaCabezal" name="PlacaCabezal" class="form-control" />
                        <input id="editChasis" name="Chasis" class="form-control" />
                        <input id="editViaje" name="ViajeDua" class="form-control" />

                    </div>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-primary">Actualizar</button>
                </div>

            </form>

        </div>
    </div>
</div>

<!--EXPORTAR INGRESOS POR HORA-->
<!-- MODAL EXPORTAR INGRESOS -->
<div class="modal fade" id="modalExportarIngresosPdf" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <form asp-action="ExportarPdf" method="get">

                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">📄 Exportar Ingresos</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <!-- FECHA -->
                    <input type="hidden" name="fecha" value="@Model.FechaSeleccionada.ToString("yyyy-MM-dd")" />

                    <!-- CHECK -->
                    <div class="form-check mb-3">
                        <input type="checkbox" id="todoDiaIngresos" class="form-check-input" checked />
                        <label class="form-check-label fw-semibold">Todo el día</label>
                    </div>

                    <!-- RANGO -->
                    <div id="rangoHorasIngresos" class="row g-2" style="display:none;">
                        <div class="col">
                            <label class="form-label">Hora inicio</label>
                            <input type="time" name="horaInicio" class="form-control" />
                        </div>
                        <div class="col">
                            <label class="form-label">Hora fin</label>
                            <input type="time" name="horaFin" class="form-control" />
                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-danger w-100">
                        Exportar PDF
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- =========================
     SCRIPTS
========================= -->
<script>
    document.addEventListener("DOMContentLoaded", function () {

        // DELETE MODAL
        const deleteModal = document.getElementById('deleteModal');
        if (deleteModal) {
            deleteModal.addEventListener('show.bs.modal', event => {
                const b = event.relatedTarget;

                document.getElementById('deleteId').value = b.dataset.id;
                document.getElementById('deleteContenedor').value = b.dataset.contenedor;
                document.getElementById('deleteMarchamos').value = b.dataset.marchamos;
                document.getElementById('deleteFecha').value = b.dataset.fecha;
                document.getElementById('deleteTransportista').value = b.dataset.transportista;
                document.getElementById('deleteCliente').value = b.dataset.cliente;
                document.getElementById('deleteTamano').value = b.dataset.tamano;
                document.getElementById('deleteChasis').value = b.dataset.chasis;
                document.getElementById('deleteViaje').value = b.dataset.viaje;
            });
        }

    });
</script>

<script>
    const ingresos = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Ingresos));

    function cargarEditar(id) {

        const item = ingresos.find(x => x.Id === id);
        if (!item) return;

        document.getElementById("editId").value = item.Id;
        document.getElementById("editContenedor").value = item.Contenedor;
        document.getElementById("editMarchamos").value = item.Marchamos;
        document.getElementById("editFechaHora").value = item.FechaHoraIngreso.substring(0, 16);
        document.getElementById("editTransportista").value = item.Transportista;
        document.getElementById("editCliente").value = item.Cliente;
        document.getElementById("editTamano").value = item.Tamaño;
        document.getElementById("editChofer").value = item.Chofer;
        document.getElementById("editPlacaCabezal").value = item.PlacaCabezal;
        document.getElementById("editChasis").value = item.Chasis;
        document.getElementById("editViaje").value = item.ViajeDua;
    }
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const btnBuscar = document.getElementById("btnBuscarActa");

        btnBuscar?.addEventListener("click", async () => {

            const contenedor = document.getElementById("inputContenedor").value.trim();
            const resultado = document.getElementById("resultadoBusqueda");

            if (!contenedor) {
                resultado.textContent = "";
                return;
            }

            try {

                const [actaRes, ingresoRes] = await Promise.all([
                    fetch(`/ActasPermanencias/BuscarContenedorEnPendientes?contenedor=${contenedor}`),
                    fetch(`/BitacoraIngresos/ObtenerDatosPorContenedor?contenedor=${contenedor}`)
                ]);

                const actaData = await actaRes.json();
                const ingresoData = await ingresoRes.json();

                resultado.textContent = actaData.encontrado
                    ? `Contenedor con ${actaData.tipo} #${actaData.numero}`
                    : "No se encontró contenedor en Actas/PAB";

                if (ingresoData) {
                    document.getElementById("Marchamos").value = ingresoData.marchamo ?? "";
                    document.getElementById("Cliente").value = ingresoData.cliente ?? "";
                    document.getElementById("Transportista").value = ingresoData.transportista ?? "";
                    document.getElementById("ViajeDua").value = ingresoData.viaje ?? "";
                }

            } catch {
                resultado.textContent = "Error al buscar información";
            }

        });

    });
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const checkbox = document.getElementById("todoDiaIngresos");
        const rango = document.getElementById("rangoHorasIngresos");

        checkbox.addEventListener("change", function () {
            if (this.checked) {
                rango.style.display = "none";
            } else {
                rango.style.display = "flex";
            }
        });

    });
</script>