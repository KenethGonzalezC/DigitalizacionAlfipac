@model List<BitacoraAlfipac.Models.Entidades.Vehiculo>

<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-0">🚗 Vehículos en almacén</h2>
            <small class="text-muted">Control de ingresos y despachos</small>
        </div>

        <div class="d-flex gap-2">
            <span class="badge bg-success">
                Activos: @Model.Count(v => v.Activo)
            </span>
            <span class="badge bg-secondary">
                Total: @Model.Count()
            </span>
        </div>
    </div>

    <!-- ACCIONES -->
    <div class="card shadow-sm mb-4">
        <div class="card-body d-flex flex-wrap gap-3 justify-content-between align-items-center">

            <div class="flex-grow-1">
                <input type="text" id="buscador" class="form-control"
                       placeholder="🔍 Buscar VIN, modelo o cliente..." />
            </div>

            <div class="d-flex gap-2">

                <button class="btn btn-success"
                        data-bs-toggle="modal"
                        data-bs-target="#modalVehiculoManual">
                    ➕ Agregar
                </button>

                <form asp-action="ExportarVehiculosPDF" method="post" class="m-0">
                    <button class="btn btn-danger">📄 PDF</button>
                </form>

                <form asp-action="ExportarVehiculosExcel" method="post" class="m-0">
                    <button class="btn btn-success">📊 Excel</button>
                </form>

            </div>
        </div>
    </div>

    <!-- TABLA -->
    <div class="card shadow-sm">
        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-hover align-middle table-striped" id="tablaVehiculos">

                    <thead class="table-light text-center">
                        <tr>
                            <th>Ingreso</th>
                            <th>Vehículo</th>
                            <th>VIN Completo</th>
                            <th>Chasis</th>
                            <th>Cliente</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    Sin registros
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var v in Model)
                            {
                                <tr class="@(v.Activo ? "" : "table-secondary")">

                                    <td class="text-nowrap">
                                        @v.FechaHoraIngreso.ToString("dd/MM/yyyy HH:mm")
                                    </td>

                                    <td class="fw-semibold">@v.Contenedor</td>
                                    <td>@v.Marchamos</td>
                                    <td>@v.Chasis</td>
                                    <td>@v.Cliente</td>

                                    <td class="text-center">
                                        <span class="badge @(v.Activo ? "bg-success" : "bg-danger")">
                                            @(v.Activo ? "Activo" : "Despachado")
                                        </span>
                                    </td>

                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2 flex-wrap">

                                            @if (v.Activo)
                                            {
                                                <a class="btn btn-sm btn-success"
                                                       asp-controller="BitacoraDespachos"
                                                       asp-action="Index"
                                                       asp-route-contenedor="@v.Contenedor"
                                                       asp-route-marchamos="@v.Marchamos"
                                                       asp-route-cliente="@v.Cliente"
                                                       asp-route-chasis="@v.Chasis">
                                                    Despachar
                                                </a>
                                            }

                                            <button class="btn btn-sm btn-outline-primary btnEditarVehiculo"
                                                    data-id="@v.Id"
                                                    data-contenedor="@v.Contenedor"
                                                    data-chasis="@v.Chasis"
                                                    data-marchamos="@v.Marchamos"
                                                    data-cliente="@v.Cliente"
                                                    data-transportista="@v.Transportista"
                                                    data-chofer="@v.Chofer"
                                                    data-placa="@v.PlacaCabezal"
                                                    data-viaje="@v.ViajeDua"
                                                    data-fechaingreso="@v.FechaHoraIngreso.ToString("yyyy-MM-ddTHH:mm")"
                                                    data-activo="@v.Activo.ToString().ToLower()">
                                                ✏️
                                            </button>

                                            <form asp-action="EliminarVehiculo"
                                                  method="post"
                                                  class="m-0"
                                                  onsubmit="return confirm('¿Seguro que deseas eliminar este vehículo?');">

                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@v.Id" />

                                                <button class="btn btn-sm btn-danger">
                                                    🗑
                                                </button>
                                            </form>

                                        </div>
                                    </td>

                                </tr>
                            }
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>

<!-- ================= MODAL CREAR ================= -->
<div class="modal fade" id="modalVehiculoManual" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content shadow">

            <form asp-action="CrearVehiculoManual" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">➕ Registrar vehículo</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <div class="row g-3">

                        <div class="col-md-4">
                            <label class="form-label">Modelo</label>
                            <input name="contenedor" class="form-control" required />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">VIN completo</label>
                            <input name="marchamos" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Cliente</label>
                            <input name="cliente" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Transportista</label>
                            <input name="transportista" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Chofer</label>
                            <input name="chofer" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Placa</label>
                            <input name="placaCabezal" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">VIN/CHASIS</label>
                            <input name="chasis" class="form-control" required />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Viaje / DUA</label>
                            <input name="viajeDua" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Fecha ingreso</label>
                            <input name="fechaHoraIngreso" type="datetime-local" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Tipo</label>
                            <input name="tamano" class="form-control" value="VEHICULO" />
                        </div>

                        <div class="col-md-4 form-check mt-4">
                            <input type="checkbox" name="activo" class="form-check-input" checked />
                            <label class="form-check-label">Activo</label>
                        </div>

                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancelar
                    </button>

                    <button class="btn btn-success">
                        Guardar
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- ================= MODAL EDITAR ================= -->
<div class="modal fade" id="modalEditarVehiculo" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content shadow">

            <form asp-action="EditarVehiculo" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header bg-warning">
                    <h5 class="modal-title">✏️ Editar vehículo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input type="hidden" id="editIdVehiculo" name="id" />

                    <div class="row g-3">

                        <div class="col-md-4">
                            <label class="form-label">Modelo</label>
                            <input id="editContenedor" name="contenedor" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">VIN completo</label>
                            <input id="editMarchamos" name="marchamos" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Cliente</label>
                            <input id="editCliente" name="cliente" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Transportista</label>
                            <input id="editTransportista" name="transportista" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Chofer</label>
                            <input id="editChofer" name="chofer" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Placa</label>
                            <input id="editPlaca" name="placaCabezal" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Chasis</label>
                            <input id="editChasis" name="chasis" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Viaje / DUA</label>
                            <input id="editViaje" name="viajeDua" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Fecha ingreso</label>
                            <input type="datetime-local"
                                   id="editFechaIngreso"
                                   name="fechaHoraIngreso"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4 form-check mt-4">
                            <input type="checkbox" id="editActivo" name="activo" value="true" class="form-check-input" />
                            <input type="hidden" name="activo" value="false" />
                            <label class="form-check-label">Activo</label>
                        </div>

                    </div>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-warning">
                        Guardar cambios
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<script>
    document.getElementById("buscador").addEventListener("keyup", function () {
        let filtro = this.value.toLowerCase();
        let filas = document.querySelectorAll("#tablaVehiculos tbody tr");

        filas.forEach(f => {
            let texto = f.innerText.toLowerCase();
            f.style.display = texto.includes(filtro) ? "" : "none";
        });
    });
</script>

<script>
    document.querySelectorAll(".btnEditarVehiculo").forEach(btn => {
        btn.addEventListener("click", function () {

            document.getElementById("editIdVehiculo").value = this.dataset.id;
            document.getElementById("editContenedor").value = this.dataset.contenedor;
            document.getElementById("editChasis").value = this.dataset.chasis;
            document.getElementById("editMarchamos").value = this.dataset.marchamos;
            document.getElementById("editCliente").value = this.dataset.cliente;
            document.getElementById("editTransportista").value = this.dataset.transportista;
            document.getElementById("editChofer").value = this.dataset.chofer;
            document.getElementById("editPlaca").value = this.dataset.placa;
            document.getElementById("editViaje").value = this.dataset.viaje;
            document.getElementById("editFechaIngreso").value = this.dataset.fechaingreso;

            document.getElementById("editActivo").checked = this.dataset.activo === "true";

            var modal = new bootstrap.Modal(document.getElementById("modalEditarVehiculo"));
            modal.show();
        });
    });
</script>
