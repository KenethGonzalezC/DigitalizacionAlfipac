@model IEnumerable<BitacoraAlfipac.Models.Entidades.TransportistaAutorizado>

@{
    ViewData["Title"] = "Transportistas Autorizados";
}

@if (TempData["Ok"] != null)
{
    <div class="alert alert-success">@TempData["Ok"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div >

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-0">🚛 Transportistas</h2>
            <small class="text-muted">
                Gestión de transportistas autorizados del sistema
            </small>
        </div>

        <div>
            <a asp-controller="Datos" asp-action="Index" class="btn btn-outline-dark">
                ← Volver
            </a>
        </div>

        <button class="btn btn-primary shadow-sm"
                data-bs-toggle="modal"
                data-bs-target="#crearModal">
            <i class="bi bi-plus-circle"></i> Nuevo Transportista
        </button>
    </div>

    <!-- CARD TABLA -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light text-center">
                        <tr>
                            <th>Nombre</th>
                            <th>Cédula Jurídica</th>
                            <th>Código</th>
                            <th style="width:170px;">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    No hay transportistas registrados
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <td class="fw-semibold">@item.Nombre</td>

                                    <td>
                                        <span class="text-muted">
                                            @(item.CedulaJuridica ?? "-")
                                        </span>
                                    </td>

                                    <td>
                                        <span class="badge bg-secondary">
                                            @(item.Codigo ?? "-")
                                        </span>
                                    </td>

                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">

                                            <button class="btn btn-sm btn-outline-warning"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#editarModal"
                                                    data-id="@item.Id"
                                                    data-nombre="@item.Nombre"
                                                    data-cedula="@item.CedulaJuridica"
                                                    data-codigo="@item.Codigo">
                                                ✏️
                                            </button>

                                            <button class="btn btn-sm btn-outline-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#eliminarModal"
                                                    data-id="@item.Id">
                                                🗑
                                            </button>

                                        </div>
                                    </td>

                                </tr>
                            }
                        }

                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>

<!-- ========================= -->
<!-- MODAL CREAR -->
<!-- ========================= -->
<div class="modal fade" id="crearModal">
    <div class="modal-dialog modal-dialog-centered">
        <form asp-action="Create" method="post" class="modal-content shadow">

            @Html.AntiForgeryToken()

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Nuevo Transportista</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <input name="Nombre" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Cédula Jurídica</label>
                    <input name="CedulaJuridica" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Código</label>
                    <input name="Codigo" class="form-control" />
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-primary">
                    Guardar
                </button>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Cancelar
                </button>
            </div>

        </form>
    </div>
</div>

<!-- ========================= -->
<!-- MODAL EDITAR -->
<!-- ========================= -->
<div class="modal fade" id="editarModal">
    <div class="modal-dialog modal-dialog-centered">
        <form asp-action="Edit" method="post" class="modal-content shadow">

            @Html.AntiForgeryToken()

            <input type="hidden" name="Id" id="editId" />

            <div class="modal-header bg-warning">
                <h5 class="modal-title">Editar Transportista</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <input name="Nombre" id="editNombre" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Cédula Jurídica</label>
                    <input name="CedulaJuridica" id="editCedula" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Código</label>
                    <input name="Codigo" id="editCodigo" class="form-control" />
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-warning">
                    Actualizar
                </button>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Cancelar
                </button>
            </div>

        </form>
    </div>
</div>

<!-- ========================= -->
<!-- MODAL ELIMINAR -->
<!-- ========================= -->
<div class="modal fade" id="eliminarModal">
    <div class="modal-dialog modal-dialog-centered">
        <form asp-action="Delete" method="post" class="modal-content shadow">

            @Html.AntiForgeryToken()

            <input type="hidden" name="id" id="deleteId" />

            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Eliminar Transportista</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">
                <p class="mb-0">
                    ¿Seguro que deseas eliminar este transportista?
                </p>
            </div>

            <div class="modal-footer">
                <button class="btn btn-danger">
                    Eliminar
                </button>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Cancelar
                </button>
            </div>

        </form>
    </div>
</div>

<!-- ========================= -->
<!-- SCRIPTS  -->
<!-- ========================= -->
@section Scripts {

    <script>

        var editarModal = document.getElementById('editarModal');

        editarModal.addEventListener('show.bs.modal', function (event) {

            var button = event.relatedTarget;

            document.getElementById('editId').value = button.getAttribute('data-id');
            document.getElementById('editNombre').value = button.getAttribute('data-nombre');
            document.getElementById('editCedula').value = button.getAttribute('data-cedula');
            document.getElementById('editCodigo').value = button.getAttribute('data-codigo');
        });


        var eliminarModal = document.getElementById('eliminarModal');

        eliminarModal.addEventListener('show.bs.modal', function (event) {

            var button = event.relatedTarget;

            document.getElementById('deleteId').value = button.getAttribute('data-id');
        });

    </script>

}