@model List<BitacoraAlfipac.Models.Entidades.ActasPermanencias>

@{
    var actas = Model.Where(x => x.Tipo == "ACTA").ToList();
    var pabs = Model.Where(x => x.Tipo == "PAB").ToList();
}

<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-0">📊 Historial de Contenedores</h2>
            <small class="text-muted">Registros procesados (ACTA y PAB)</small>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-dark">
                ← Volver
            </a>

            <form method="post" asp-action="ExportarHistorialPDF" class="m-0">
                <input type="hidden" name="nombre" value="@User.Identity.Name" />
                <button class="btn btn-success">
                    📄 Exportar PDF
                </button>
            </form>

            <form asp-action="LimpiarHistorialIngresados" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <button class="btn btn-danger"
                        onclick="return confirm('¿Seguro que deseas eliminar todo el historial?');">
                    🗑 Limpiar
                </button>
            </form>
        </div>
    </div>

    <!-- FILTRO -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <form method="get" asp-action="HistorialFiltro" class="row g-3 align-items-end">

                <div class="col-md-3">
                    <label class="form-label">Filtrar por fecha</label>
                    <input type="date" name="fechaFiltro"
                           class="form-control"
                           value="@ViewBag.FechaFiltro" />
                </div>

                <div class="col-md-2">
                    <button class="btn btn-primary w-100">
                        Filtrar
                    </button>
                </div>

                <div>
                    <a asp-action="Historial" class="btn btn-secondary">
                        Hoy
                    </a>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Buscar contenedor</label>
                    <input id="buscarContenedorHist"
                           class="form-control"/>
                </div>

                <div class="col-md-2">
                    <button type="button" id="btnBuscarHist" class="btn btn-warning w-100">
                        🔍 Buscar
                    </button>
                </div>

            </form>

        </div>
    </div>

    <!-- ================= ACTAS ================= -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <h5 class="fw-bold text-danger mb-3">ACTAS</h5>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light text-center">
                        <tr>
                            <th>Contenedor</th>
                            <th>Número</th>
                            <th>Viaje</th>
                            <th>Detalle</th>
                            <th>Cliente</th>
                            <th>Fecha</th>
                            <th>Resultado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!actas.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    Sin registros
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in actas)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.Contenedor</td>
                                    <td>@item.Numero</td>
                                    <td>@item.Viaje</td>
                                    <td>@item.Detalle</td>
                                    <td>@item.Cliente</td>

                                    <td>
                                        @item.FechaHoraIngresoContenedor?.ToString("dd/MM/yyyy HH:mm")
                                    </td>

                                    <td>
                                        @if (item.AplicadoCorrectamente)
                                        {
                                            <span class="badge bg-success">Correcta</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Incorrecta</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">

                                            <button class="btn btn-sm btn-outline-primary btnEditarHist">
                                                ✏️
                                            </button>

                                            <form asp-action="QuitarIngreso"
                                                  method="post"
                                                  onsubmit="return confirmarVolverPendiente();"
                                                  class="m-0">

                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />

                                                <button class="btn btn-sm btn-warning">
                                                    ↩
                                                </button>
                                            </form>

                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

    <!-- ================= PAB ================= -->
    <div class="card shadow-sm">
        <div class="card-body">

            <h5 class="fw-bold text-primary mb-3">Permanencias a Bordo (PAB)</h5>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light text-center">
                        <tr>
                            <th>Contenedor</th>
                            <th>Número</th>
                            <th>Viaje</th>
                            <th>Detalle</th>
                            <th>Cliente</th>
                            <th>Fecha</th>
                            <th>Resultado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!pabs.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    Sin registros
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in pabs)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.Contenedor</td>
                                    <td>@item.Numero</td>
                                    <td>@item.Viaje</td>
                                    <td>@item.Detalle</td>
                                    <td>@item.Cliente</td>

                                    <td>
                                        @item.FechaHoraIngresoContenedor?.ToString("dd/MM/yyyy HH:mm")
                                    </td>

                                    <td>
                                        <span class="badge @(item.AplicadoCorrectamente ? "bg-success" : "bg-danger")">
                                            @(item.AplicadoCorrectamente ? "Correcta" : "Incorrecta")
                                        </span>
                                    </td>

                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">

                                            <button class="btn btn-sm btn-outline-primary btnEditarHist">
                                                ✏️
                                            </button>

                                            <form asp-action="QuitarIngreso"
                                                  method="post"
                                                  onsubmit="return confirmarVolverPendiente();"
                                                  class="m-0">

                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />

                                                <button class="btn btn-sm btn-warning">
                                                    ↩
                                                </button>
                                            </form>

                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

</div>

<!-- MODAL EDITAR -->
<div class="modal fade" id="editarModalHist" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="EditarRegistro" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="Id" id="editIdHist" />

                <div class="modal-header bg-primary text-white">
                    <h5>Editar Registro</h5>
                </div>

                <div class="modal-body row g-3">

                    <div class="col-md-4">
                        <label>Tipo</label>
                        <input id="editTipoHist" class="form-control" readonly />
                    </div>

                    <div class="col-md-4">
                        <label>Contenedor</label>
                        <input id="editContenedorHist" class="form-control" readonly />
                    </div>

                    <div class="col-md-4">
                        <label>Número</label>
                        <input name="Numero" id="editNumeroHist" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label>Viaje</label>
                        <input name="Viaje" id="editViajeHist" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label>Cliente</label>
                        <input name="Cliente" id="editClienteHist" class="form-control" />
                    </div>

                    <div class="col-md-12">
                        <label>Detalle</label>
                        <textarea name="Detalle" id="editDetalleHist" class="form-control"></textarea>
                    </div>

                    <div class="col-md-6">
                        <label>Fecha</label>
                        <input type="datetime-local" name="FechaIngreso" id="editFechaIngresoHist" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label>Resultado</label>
                        <select name="AplicadoCorrectamente" id="editAplicadoCorrectamenteHist" class="form-select">
                            <option value="true">Correcta</option>
                            <option value="false">Incorrecta</option>
                        </select>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button class="btn btn-success">Guardar</button>
                </div>

            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        function abrirModalHist(data) {

            if (!data || !data.encontrado) {
                alert("No existe");
                return;
            }

            document.getElementById("editIdHist").value = data.id;
            document.getElementById("editTipoHist").value = data.tipo;
            document.getElementById("editContenedorHist").value = data.contenedor;
            document.getElementById("editNumeroHist").value = data.numero;
            document.getElementById("editViajeHist").value = data.viaje;
            document.getElementById("editClienteHist").value = data.cliente;
            document.getElementById("editDetalleHist").value = data.detalle;
            document.getElementById("editFechaIngresoHist").value = data.fechaIngreso ?? "";

            document.getElementById("editAplicadoCorrectamenteHist").value =
                (data.aplicadoCorrectamente ?? false).toString();

            const modal = new bootstrap.Modal(document.getElementById('editarModalHist'));
            modal.show();
        }

        // 🔍 BUSCAR
        document.getElementById("btnBuscarHist")?.addEventListener("click", function (e) {

            e.preventDefault();

            const cont = document.getElementById("buscarContenedorHist").value.trim();

            if (!cont) return;

            fetch(`/ActasPermanencias/BuscarContenedor?contenedor=${cont}`)
                .then(r => r.json())
                .then(data => abrirModalHist(data))
                .catch(() => alert("Error en la búsqueda"));
        });

        // ✏️ EDITAR
        document.addEventListener("click", function (e) {

            const btn = e.target.closest(".btnEditarHist");

            if (!btn) return;

            const fila = btn.closest("tr");
            const contenedor = fila.children[0].innerText.trim();

            fetch(`/ActasPermanencias/BuscarContenedor?contenedor=${contenedor}`)
                .then(r => r.json())
                .then(data => abrirModalHist(data))
                .catch(() => alert("Error al abrir registro"));
        });

    });
</script>