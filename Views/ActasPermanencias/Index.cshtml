@model List<BitacoraAlfipac.Models.Entidades.ActasPermanencias>

@{
    ViewData["Title"] = "Actas & PAB";
}

@if (TempData["Ok"] != null)
{
    <div class="alert alert-success">@TempData["Ok"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@{
    var actas = Model.Where(x => x.Tipo == "ACTA").ToList();
    var pabs = Model.Where(x => x.Tipo == "PAB").ToList();
}

<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h2 class="fw-bold mb-0">Actas & Permanencias</h2>
            <small class="text-muted">Gestión de ACTA y PAB</small>
        </div>

        <div class="d-flex gap-2">
            <a asp-controller="PabMercanciaSuceptible"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                📘 Códigos PAB
            </a>

            <a asp-action="Historial" class="btn btn-dark">
                🕓 Historial
            </a>
        </div>
    </div>

    <!-- ALERTAS -->
    @if (TempData["Ok"] != null)
    {
        <div class="alert alert-success">@TempData["Ok"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <!-- ================= CREAR ================= -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="fw-bold mb-3">Crear registro</h5>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-3">

                    <div class="col-md-2">
                        <label class="form-label">Tipo</label>
                        <select name="Tipo" id="tipoSelect" class="form-select" required>
                            <option value="ACTA">ACTA</option>
                            <option value="PAB">PAB</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Contenedor</label>
                        <div class="input-group">
                            <input name="Contenedor" id="contenedorInput"
                                   class="form-control" required />

                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    id="btnBuscarContenedor">
                                🔍
                            </button>
                        </div>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Número</label>
                        <input name="Numero" id="numeroInput"
                               class="form-control" required />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Viaje</label>
                        <input name="Viaje" id="viajeInput"
                               class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Cliente</label>
                        <input name="Cliente" id="clienteInput"
                               class="form-control" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">Detalle</label>
                        <textarea name="Detalle"
                                  id="detalleTextarea"
                                  class="form-control"
                                  rows="2"></textarea>
                    </div>

                    <div class="col-md-2">
                        <button class="btn btn-primary w-100">
                            ➕ Crear
                        </button>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <!-- ================= BUSQUEDA ================= -->
    <div class="card shadow-sm mb-4">
        <div class="card-body d-flex flex-wrap gap-3 align-items-end">

            <div class="col-md-4">
                <label class="form-label">Buscar contenedor</label>
                <input id="buscarContenedor" class="form-control" />
            </div>

            <div class="col-md-2">
                <button id="btnBuscar" class="btn btn-warning w-100">
                    Buscar
                </button>
            </div>

            <div class="col-md-3">
                <form method="post" asp-action="ExportarPendientesPDF">
                    <input type="hidden" name="nombre" value="@User.Identity.Name" />
                    <button type="submit" class="btn btn-success w-100">
                        📄 Exportar PDF
                    </button>
                </form>
            </div>

        </div>
    </div>

    <!-- ================= ACTAS ================= -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <h5 class="fw-bold text-danger mb-3">ACTAS</h5>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Contenedor</th>
                            <th>Número</th>
                            <th>Viaje</th>
                            <th>Detalle</th>
                            <th>Cliente</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in actas)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Contenedor</td>
                                <td>@item.Numero</td>
                                <td>@item.Viaje</td>
                                <td>@item.Detalle</td>
                                <td>@item.Cliente</td>

                                <td>
                                    <span class="badge bg-warning text-dark">
                                        Pendiente
                                    </span>
                                </td>

                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">

                                        <button class="btn btn-sm btn-outline-primary btnEditar">
                                            Editar
                                        </button>

                                        <form asp-action="EliminarPendiente"
                                              method="post"
                                              onsubmit="return confirmarEliminacion();"
                                              class="m-0">

                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />

                                            <button class="btn btn-sm btn-danger">
                                                Eliminar
                                            </button>
                                        </form>

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

    <!-- ================= PAB ================= -->
    <div class="card shadow-sm">
        <div class="card-body">

            <h5 class="fw-bold text-primary mb-3">Permanencias a Bordo (PAB)</h5>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Contenedor</th>
                            <th>Número</th>
                            <th>Viaje</th>
                            <th>Detalle</th>
                            <th>Cliente</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in pabs)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Contenedor</td>
                                <td>@item.Numero</td>
                                <td>@item.Viaje</td>
                                <td>@item.Detalle</td>
                                <td>@item.Cliente</td>

                                <td>
                                    <span class="badge bg-warning text-dark">
                                        Pendiente
                                    </span>
                                </td>

                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">

                                        <button class="btn btn-sm btn-outline-primary btnEditar">
                                            Editar
                                        </button>

                                        <form asp-action="EliminarPendiente"
                                              method="post"
                                              onsubmit="return confirmarEliminacion();"
                                              class="m-0">

                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />

                                            <button class="btn btn-sm btn-danger">
                                                Eliminar
                                            </button>
                                        </form>

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>

</div>

<!-- MODAL EDITAR -->
<div class="modal fade" id="editarModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <form asp-action="EditarRegistro" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Editar Acta / PAB</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" name="Id" id="editId" />

                    <div class="row g-3">

                        <div class="col-md-4">
                            <label>Tipo</label>
                            <input id="editTipo" class="form-control" readonly />
                        </div>

                        <div class="col-md-4">
                            <label>Contenedor</label>
                            <input id="editContenedor" class="form-control" readonly />
                        </div>

                        <div class="col-md-4">
                            <label>Número</label>
                            <input name="Numero" id="editNumero" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label>Viaje</label>
                            <input name="Viaje" id="editViaje" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label>Cliente</label>
                            <input name="Cliente" id="editCliente" class="form-control" />
                        </div>

                        <div class="col-md-12">
                            <label>Detalle</label>
                            <textarea name="Detalle" id="editDetalle" class="form-control"></textarea>
                        </div>

                        <div class="col-md-6">
                            <label>Fecha Ingreso</label>
                            <input type="datetime-local" name="FechaIngreso" id="editFechaIngreso" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label>¿Aplicada correctamente?</label>
                            <select name="AplicadoCorrectamente" id="editAplicadoCorrectamente" class="form-select">
                                <option value="true">Correcta</option>
                                <option value="false">Incorrecta</option>
                            </select>
                        </div>

                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-success">Guardar cambios</button>
                </div>

            </form>

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        function abrirModal(data){
            document.getElementById("editId").value = data.id;
            document.getElementById("editTipo").value = data.tipo;
            document.getElementById("editContenedor").value = data.contenedor;
            document.getElementById("editNumero").value = data.numero;
            document.getElementById("editViaje").value = data.viaje;
            document.getElementById("editCliente").value = data.cliente;
            document.getElementById("editDetalle").value = data.detalle;
            document.getElementById("editFechaIngreso").value = data.fechaIngreso ?? "";
            document.getElementById("editAplicadoCorrectamente").value =
                (data.aplicadoCorrectamente ?? false).toString();

            new bootstrap.Modal(document.getElementById('editarModal')).show();
        }

        // 🔍 BUSCAR CONTENEDOR GENERAL
            const btnBuscar = document.getElementById("btnBuscar");

    if (btnBuscar) {
        btnBuscar.addEventListener("click", () => {

            const input = document.getElementById("buscarContenedor");
            const cont = input.value.trim();

            if (!cont) {
                alert("Ingrese un contenedor");
                input.focus();
                return;
            }

            fetch(`/ActasPermanencias/BuscarContenedor?contenedor=${cont}`)
                .then(r => r.json())
                .then(data => {
                    if (data.encontrado) {
                        abrirModal(data);
                    } else {
                        alert("No existe");
                    }
                })
                .catch(() => alert("Error consultando"));
        });
    }

        // ✏️ EDITAR DESDE TABLA
        document.querySelectorAll(".btnEditar").forEach(btn => {
            btn.addEventListener("click", function () {

                const contenedor = this.closest("tr").children[0].innerText;

                fetch(`/ActasPermanencias/BuscarContenedor?contenedor=${contenedor}`)
                    .then(r => r.json())
                    .then(data => abrirModal(data));
            });
        });

        // 📄 AUTO DESCRIPCIÓN PAB
        document.getElementById("numeroInput")?.addEventListener("blur", function () {

            let tipo = document.getElementById("tipoSelect").value;
            let numero = this.value;

            if (tipo !== "PAB" || numero === "") return;

            fetch(`/ActasPermanencias/ObtenerDescripcionPab?codigo=${numero}`)
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById("detalleTextarea").value = data.descripcion;
                    } else {
                        alert("⚠️ No se encontró un PAB con ese código.");
                    }
                });
        });

        // 📦 BUSCAR CONTENEDOR (AUTOCOMPLETE)
        document.getElementById("btnBuscarContenedor")?.addEventListener("click", function () {

            let contenedor = document.getElementById("contenedorInput").value;

            if (!contenedor) return;

            fetch(`/ActasPermanencias/ObtenerDatosContenedor?contenedor=${contenedor}`)
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById("viajeInput").value = data.viaje;
                        document.getElementById("clienteInput").value = data.cliente;
                    } else {
                        alert("⚠️ No se encontró información.");
                    }
                });
        });

    });

    // ❗ CONFIRMAR ELIMINACIÓN
    function confirmarEliminacion() {
        return confirm("¿Seguro que deseas eliminar este registro?");
    }
</script>