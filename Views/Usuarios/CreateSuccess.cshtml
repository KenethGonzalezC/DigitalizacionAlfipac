@{
    ViewData["Title"] = "Usuario creado";
}

<div class="container mt-4">

    <!-- CARD PRINCIPAL -->
    <div class="card shadow-sm border-success">

        <div class="card-header bg-success text-white">
            <h5 class="mb-0">✅ Usuario creado correctamente</h5>
        </div>

        <div class="card-body">

            <div class="mb-3">
                <label class="form-label text-muted">Usuario</label>
                <div class="fw-semibold">
                    @TempData["UsuarioCreado"]
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label text-muted">Contraseña generada</label>

                <div class="alert alert-warning d-flex justify-content-between align-items-center">

                    <span class="fw-bold">
                        @TempData["PasswordCreada"]
                    </span>

                </div>
            </div>

            <div class="alert alert-danger small">
                ⚠️ Copie esta contraseña ahora. No volverá a mostrarse.
            </div>

            <div class="d-flex justify-content-end">

                <a asp-action="Index"
                       class="btn btn-primary">
                    ← Volver al listado
                </a>

            </div>

        </div>

    </div>

</div>