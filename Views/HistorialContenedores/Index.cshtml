@model List<BitacoraAlfipac.Models.Entidades.HistorialContenedor>

@{
    ViewData["Title"] = "Historial de Contenedores";
    var paginaActual = ViewBag.PaginaActual as int? ?? 1;
    var totalPaginas = ViewBag.TotalPaginas as int? ?? 1;
    var contenedorBuscado = ViewBag.ContenedorBuscado as string;
    var totalRegistros = ViewBag.TotalRegistros as int? ?? 0;
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="mb-0">📦 Historial de Contenedores</h3>
            <small class="text-muted">Total: @totalRegistros registros</small>
        </div>
    </div>

    <!-- ACCIONES -->
    <div class="card shadow-sm mb-3">
        <div class="card-body d-flex flex-wrap gap-2">

            <a asp-action="ExportarPdf"
                   asp-route-contenedor="@contenedorBuscado"
                   class="btn btn-danger btn-sm">
                📄 PDF
            </a>

            <a asp-action="ExportarExcel"
                   asp-route-contenedor="@contenedorBuscado"
                   class="btn btn-success btn-sm">
                📊 Excel
            </a>

            <button class="btn btn-warning btn-sm"
                    data-bs-toggle="modal"
                    data-bs-target="#limpiarHistorialModal">
                🧹 Limpiar antiguos
            </button>

        </div>
    </div>

    <!-- BUSCADOR -->
    <div class="card shadow-sm mb-3">
        <div class="card-body">

            <form method="get" class="row g-2 align-items-end">

                <div class="col-md-4">
                    <label class="form-label">Contenedor</label>
                    <input type="text"
                           name="contenedor"
                           class="form-control"
                           value="@contenedorBuscado" />
                </div>

                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary">
                        🔎 Buscar
                    </button>
                </div>

                <div class="col-md-2 d-grid">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Limpiar
                    </a>
                </div>

            </form>

        </div>
    </div>

    <!-- TABLA -->
    <div class="card shadow-sm">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>Estado</th>
                            <th>Contenedor</th>
                            <th>Ingreso</th>
                            <th>Salida</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    No hay registros disponibles
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                bool activo = item.FechaHoraSalida == null;

                                <tr>
                                    <td>
                                        @if (activo)
                                        {
                                            <span class="badge bg-success">ACTIVO</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">DESPACHADO</span>
                                        }
                                    </td>

                                    <td class="fw-semibold">
                                        @item.Contenedor
                                    </td>

                                    <td>
                                        @(item.FechaHoraIngreso?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                                    </td>

                                    <td>
                                        @(item.FechaHoraSalida?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

    <!-- PAGINACIÓN -->
    @if (totalPaginas > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">

                <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                    <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(paginaActual - 1)"
                           asp-route-contenedor="@contenedorBuscado">
                        ←
                    </a>
                </li>

                @for (int i = 1; i <= totalPaginas; i++)
                {
                    <li class="page-item @(i == paginaActual ? "active" : "")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-contenedor="@contenedorBuscado">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                    <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(paginaActual + 1)">
                        →
                    </a>
                </li>

            </ul>
        </nav>
    }

</div>

<div class="modal fade" id="limpiarHistorialModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="LimpiarAntiguos" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header bg-warning">
                    <h5>Limpiar historial antiguo</h5>
                </div>

                <div class="modal-body">
                    Se eliminarán registros con más de
                    <strong>6 meses</strong> desde su salida.
                    ¿Desea continuar?
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-warning">Sí, limpiar</button>
                </div>
            </form>
        </div>
    </div>
</div>

