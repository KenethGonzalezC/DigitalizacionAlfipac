@model BitacoraAlfipac.Models.Entidades.ContenedorRefrigerado

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">

        <div>
            <h3 class="mb-0">
                ❄️ Contenedor Refrigerado
            </h3>
            <small class="text-muted">
                Detalle operativo y control de temperatura
            </small>
        </div>

        <a asp-action="Refrigerados" class="btn btn-outline-secondary">
            ← Volver
        </a>

    </div>

    <!-- INFO PANEL -->
    <div class="card shadow-sm mb-4">

        <div class="card-body">

            <div class="row g-3">

                <div class="col-md-4">
                    <label class="text-muted">Contenedor</label>
                    <div class="fw-semibold fs-5">
                        @Model.Contenedor
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="text-muted">Ingreso</label>
                    <div>
                        @(Model.FechaHoraIngreso?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="text-muted">Conexión</label>
                    <div>
                        @(Model.FechaHoraConexion?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="text-muted">Set Point</label>
                    <div class="fw-semibold">
                        @(Model.SetPoint?.ToString("0.0") ?? "—") °C
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="text-muted">Despacho</label>
                    <div>
                        @(Model.FechaHoraDespacho?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="text-muted">Desconexión</label>
                    <div>
                        @(Model.FechaHoraDesconexion?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                    </div>
                </div>

            </div>

        </div>

    </div>

    <!-- EXPORT -->
    <div class="card shadow-sm mb-4">

        <div class="card-body d-flex flex-wrap gap-2 align-items-center">

            <strong class="me-2">📤 Exportar:</strong>

            <a asp-action="ExportarPdf"
                   asp-route-id="@Model.Id"
                   class="btn btn-danger btn-sm">
                PDF
            </a>

            <a asp-action="ExportarExcel"
                   asp-route-id="@Model.Id"
                   class="btn btn-success btn-sm">
                Excel
            </a>

            <a asp-action="ExportarCsv"
                   asp-route-id="@Model.Id"
                   class="btn btn-secondary btn-sm">
                CSV
            </a>

        </div>

    </div>

    <!-- HISTORIAL -->
    <div class="card shadow-sm">

        <div class="card-header bg-white">
            <h5 class="mb-0">📊 Historial de Temperaturas</h5>
        </div>

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover table-sm mb-0 align-middle">

                    <thead class="table-light">
                        <tr>
                            <th>Fecha</th>
                            <th>Temperatura</th>
                            <th>Observación</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model.RegistrosTemperatura != null && Model.RegistrosTemperatura.Any())
                        {
                            foreach (var r in Model.RegistrosTemperatura.OrderByDescending(x => x.FechaHora))
                            {
                                <tr>

                                    <td>
                                        @r.FechaHora.ToString("dd/MM/yyyy HH:mm")
                                    </td>

                                    <td class="fw-semibold">
                                        @r.Temperatura.ToString("0.0") °C
                                    </td>

                                    <td>
                                        @r.Observacion
                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">
                                    Sin registros de temperatura
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>