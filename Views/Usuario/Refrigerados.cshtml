@model dynamic

<h2 class="mb-4">Contenedores Refrigerados</h2>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-4">
        <input name="contenedor"
               value="@ViewBag.Busqueda"
               class="form-control"
               placeholder="Buscar contenedor..." />
    </div>

    <div class="col-md-2">
        <button class="btn btn-primary w-100">
            Buscar
        </button>
    </div>

    <div class="col-md-2">
        <a asp-action="Refrigerados"
               class="btn btn-secondary w-100">
            Limpiar
        </a>
    </div>
</form>

<h4 class="text-success">🟢 Activos</h4>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Contenedor</th>
            <th>Ingreso</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in ViewBag.Activos)
        {
            <tr>
                <td>
                    <a asp-action="DetalleRefrigerado"
                           asp-route-id="@c.Id">
                        @c.Contenedor
                    </a>
                </td>
                <td>
                    @(c.FechaHoraIngreso?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                </td>
            </tr>
        }
    </tbody>
</table>

<h4 class="text-danger mt-5">🔴 Despachados</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Contenedor</th>
            <th>Ingreso</th>
            <th>Despacho</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in ViewBag.Despachados)
        {
            <tr>
                <td>
                    <a asp-action="DetalleRefrigerado"
                           asp-route-id="@c.Id">
                        @c.Contenedor
                    </a>
                </td>
                <td>
                    @(c.FechaHoraIngreso?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                </td>
                <td>
                    @(c.FechaHoraDespacho?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                </td>
            </tr>
        }
    </tbody>
</table>