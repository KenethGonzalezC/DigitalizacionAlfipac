@{
    ViewData["Title"] = "Inicio";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="mb-4">

        <h3 class="mb-0 fw-semibold">
            🧭 Panel principal (Solo Lecutra)
        </h3>

        <small class="text-muted">
            Accesos rápidos al sistema de gestión
        </small>

    </div>

    <!-- GRID -->
    <div class="row g-4">

        <!-- BITÁCORA -->
        <div class="col-md-6 col-lg-4">

            <a asp-controller="Bitacora"
                   asp-action="Index"
                   class="text-decoration-none">

                <div class="card h-100 shadow-sm dashboard-card border-0">

                    <div class="card-body">

                        <div class="d-flex align-items-center mb-2">
                            <span class="fs-4 me-2">📋</span>
                            <h5 class="mb-0">Bitácora del día</h5>
                        </div>

                        <p class="text-muted mb-0">
                            Registro de movimientos del almacén fiscal.
                        </p>

                    </div>

                </div>

            </a>

        </div>               

        <!-- INVENTARIO -->
        <div class="col-md-6 col-lg-4">

            <a asp-controller="Inventario"
                   asp-action="InventarioLectura"
                   class="text-decoration-none">

                <div class="card h-100 shadow-sm dashboard-card border-0">

                    <div class="card-body">

                        <div class="d-flex align-items-center mb-2">
                            <span class="fs-4 me-2">📊</span>
                            <h5 class="mb-0">Inventario</h5>
                        </div>

                        <p class="text-muted mb-0">
                            Consulta de inventario en modo lectura.
                        </p>

                    </div>

                </div>

            </a>

        </div>

        <!-- REFRIGERADOS -->
        <div class="col-md-6 col-lg-4">

            <a asp-controller="Usuario"
                   asp-action="Refrigerados"
                   class="text-decoration-none">

                <div class="card h-100 shadow-sm dashboard-card border-0">

                    <div class="card-body">

                        <div class="d-flex align-items-center mb-2">
                            <span class="fs-4 me-2">❄️</span>
                            <h5 class="mb-0">Refrigerados</h5>
                        </div>

                        <p class="text-muted mb-0">
                            Gestión de contenedores refrigerados.
                        </p>

                    </div>

                </div>

            </a>

        </div>

        <!-- HISTORIAL -->
        <div class="col-md-6 col-lg-4">

            <a asp-controller="HistorialContenedores"
                   asp-action="Index"
                   class="text-decoration-none">

                <div class="card h-100 shadow-sm dashboard-card border-0">

                    <div class="card-body">

                        <div class="d-flex align-items-center mb-2">
                            <span class="fs-4 me-2">📦</span>
                            <h5 class="mb-0">Historial de contenedores</h5>
                        </div>

                        <p class="text-muted mb-0">
                            Consulta histórica de movimientos.
                        </p>

                    </div>

                </div>

            </a>

        </div>

    </div>

</div>

<style>
    .dashboard-card {
        transition: all 0.2s ease-in-out;
        border-radius: 12px;
    }

        .dashboard-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.12);
        }
</style>